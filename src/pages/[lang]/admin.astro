---
import '../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import AdminDashboard from '../../components/admin/AdminDashboard';
import { useTranslations } from '../../lib/i18n';
import Analytics from '../../components/Analytics.astro';

export async function getStaticPaths() {
  return [
    { params: { lang: 'en-us' } },
    { params: { lang: 'de-de' } },
    { params: { lang: 'fr-fr' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang || 'en-us');
---

<!DOCTYPE html>
<html lang={lang} data-theme="sage-minimalist">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/logo.png" />
  <title>{t.nav.admin} | EcoRebates</title>
  <meta name="description" content="Manage regions, cities, rates, and active rebate policies dynamically." />
  <ClientRouter />
  <script is:inline>
    // 1. Immediately apply saved theme to avoid flashing
    const savedTheme = localStorage.getItem('theme') || 'sage-minimalist';
    document.documentElement.setAttribute('data-theme', savedTheme);

    // 2. Re-bind event handlers on Astro page loads (ClientRouter compatibility)
    document.addEventListener('astro:page-load', () => {
      const activeTheme = localStorage.getItem('theme') || 'sage-minimalist';
      document.documentElement.setAttribute('data-theme', activeTheme);

      const themeSelect = document.getElementById('theme-select');
      if (themeSelect) {
        themeSelect.value = activeTheme;
        themeSelect.addEventListener('change', (e) => {
          const theme = e.target.value;
          localStorage.setItem('theme', theme);
          document.documentElement.setAttribute('data-theme', theme);
        });
      }

      const langSelect = document.getElementById('lang-select');
      if (langSelect) {
        langSelect.addEventListener('change', (e) => {
          const targetLang = e.target.value;
          const pathParts = window.location.pathname.split('/').filter(Boolean);
          
          if (pathParts.length === 0) {
            window.location.href = `/${targetLang}/directory`;
          } else {
            const supportedLangs = ['en-us', 'de-de', 'fr-fr'];
            if (supportedLangs.includes(pathParts[0])) {
              pathParts[0] = targetLang;
            } else {
              pathParts.unshift(targetLang);
            }
            window.location.href = `/${pathParts.join('/')}${window.location.search}`;
          }
        });
      }
    });
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Open+Sans:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body class="min-h-screen flex flex-col justify-between">
  <!-- Navbar -->
  <header class="border-b border-[var(--color-border)] bg-[var(--bg-primary)]/80 backdrop-blur-md sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-bold text-lg tracking-tight text-[var(--text-main)] hover:opacity-80 transition-opacity group">
        <img src="/logo.png" alt="EcoRebates Logo" class="w-9 h-9 object-contain rounded-lg transition-transform duration-300 group-hover:scale-105" width="36" height="36" />
        <span>EcoRebates</span>
      </a>
      <nav class="hidden md:flex items-center gap-6 text-sm font-semibold text-[var(--text-muted)]">
        <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.directory}</a>
        <a href={`/${lang}/search`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.search}</a>
        <a href={`/${lang}/compare`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.compare}</a>
        <a href={`/${lang}/compliance`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.compliance}</a>
              <a href={`/${lang}/blog`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.blog}</a>
</nav>
      <div class="flex items-center gap-3">
        <!-- Lang Selector -->
        <select 
          id="lang-select" 
          class="bg-[var(--bg-primary)] border border-[var(--color-border)] text-[var(--text-main)] text-sm rounded-xl px-2.5 py-1.5 outline-none font-semibold cursor-pointer transition-all hover:border-[var(--color-accent)]"
        >
          <option value="en-us" selected={lang === 'en-us'} class="bg-[var(--bg-primary)] text-[var(--text-main)]">EN-US</option>
          <option value="de-de" selected={lang === 'de-de'} class="bg-[var(--bg-primary)] text-[var(--text-main)]">DE-DE</option>
          <option value="fr-fr" selected={lang === 'fr-fr'} class="bg-[var(--bg-primary)] text-[var(--text-main)]">FR-FR</option>
        </select>

        <!-- Theme Selector -->
        <select 
          id="theme-select"
          class="bg-[var(--bg-primary)] border border-[var(--color-border)] text-[var(--text-main)] text-sm rounded-xl px-2.5 py-1.5 outline-none font-semibold cursor-pointer transition-all hover:border-[var(--color-accent)]"
        >
          <option value="sage-minimalist" class="bg-[var(--bg-primary)] text-[var(--text-main)]">Sage Minimalist</option>
          <option value="dark-forest" class="bg-[var(--bg-primary)] text-[var(--text-main)]">Dark Forest Luxury</option>
          <option value="mint-tech" class="bg-[var(--bg-primary)] text-[var(--text-main)]">Mint & Clean Tech</option>
        </select>

        <a href={`/${lang}/directory`} class="bg-[var(--color-accent)] text-white font-bold text-sm px-4 py-2 rounded-xl">
          {t.nav.browseDir}
        </a>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16 flex-grow w-full" transition:animate="fade">
    <AdminDashboard client:load lang={lang} />
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-border)] bg-[var(--bg-primary)] py-8 text-center text-xs text-[var(--text-muted)]">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>{t.footer.copyright}</div>
      <div class="flex gap-4 flex-wrap justify-center">
        <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)]">{t.footer.directory}</a>
        <a href={`/${lang}/search`} class="hover:text-[var(--text-main)]">{t.footer.search}</a>
        <a href={`/${lang}/compare`} class="hover:text-[var(--text-main)]">{t.footer.compare}</a>
        <a href={`/${lang}/compliance`} class="hover:text-[var(--text-main)]">{t.footer.compliance}</a>
                <a href={`/${lang}/blog`} class="hover:text-[var(--text-main)]">{t.footer.blog}</a>
<a href={`/${lang}/privacy`} class="hover:text-[var(--text-main)]">{t.footer.privacy}</a>
        <a href={`/${lang}/terms`} class="hover:text-[var(--text-main)]">{t.footer.terms}</a>
      </div>
    </div>
  </footer>
</body>
</html>
