---
import '../../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { supabase } from '../../../lib/supabase';
import { useTranslations } from '../../../lib/i18n';
import Analytics from '../../../components/Analytics.astro';
import Navbar from '../../../components/Navbar.astro';
import { COUNTRY_METADATA } from '../../../data/regions';

export async function getStaticPaths() {
  const langs = ['en-us', 'de-de', 'fr-fr'];
  const paths = [];

  if (supabase) {
    try {
      const { data } = await supabase
        .from('rebates')
        .select('technology_category')
        .eq('is_active', true);

      if (data && data.length > 0) {
        // Extract distinct category values and slugify them
        const categories = [...new Set(data.map(r => r.technology_category))];
        const category_slugs = categories.map(cat =>
          cat
            .toLowerCase()
            .replace(/[^a-z0-9\s-]/g, '')
            .trim()
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-')
        );
        
        paths.push(
          ...langs.flatMap(lang =>
            category_slugs.map(category_slug => ({ params: { lang, category_slug } }))
          )
        );
      }
    } catch (err) {
      console.error('Failed to generate static paths for categories:', err);
    }
  }

  // Fallbacks if DB is empty or fails
  if (paths.length === 0) {
    const fallbackCategories = [
      'solar',
      'wind',
      'battery-storage-program',
      'heat-pump',
      'federal-tax-incentive',
      'local-utility-rebate'
    ];
    paths.push(
      ...langs.flatMap(lang =>
        fallbackCategories.map(category_slug => ({ params: { lang, category_slug } }))
      )
    );
  }

  return paths;
}

const { lang, category_slug } = Astro.params;
const t = useTranslations(lang || 'en-us');

interface Rebate {
  id?: string;
  slug: string;
  authority_name: string;
  technology_category?: string;
  incentive_value: number;
  incentive_type: string;
  description: string;
  is_active?: boolean;
  regions?: {
    country_code?: string;
    state_province?: string;
    city?: string;
  };
  isGrouped?: boolean;
  citiesList?: string[];
}

// Helper to slugify categories
function slugifyCategory(category: string): string {
  return category
    .toLowerCase()
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-');
}

// Fetch database records
let rebates: Rebate[] = [];
let matchedCategory = '';

if (supabase) {
  try {
    // First, find the matching display name of the category
    const { data: distinctData } = await supabase
      .from('rebates')
      .select('technology_category');
      
    if (distinctData) {
      const uniqueCats = [...new Set(distinctData.map(r => r.technology_category))];
      const found = uniqueCats.find(cat => slugifyCategory(cat) === category_slug);
      if (found) {
        matchedCategory = found;
      }
    }

    if (matchedCategory) {
      const { data: rebatesData } = await supabase
        .from('rebates')
        .select('*, regions(*)')
        .eq('technology_category', matchedCategory)
        .eq('is_active', true);
        
      if (rebatesData) {
        rebates = rebatesData;
      }
    }
  } catch (err) {
    console.error('Failed to query rebates for category:', err);
  }
}

// Fallback category title if not found in database
const displayCategory = matchedCategory || (category_slug ? category_slug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ') : 'Energy');

// Localized strings
const l10n = {
  'en-us': {
    titleSuffix: 'Rebates Worldwide — 2026 Guide',
    metaDescStart: 'Compare active rebates and green energy incentives.',
    metaDescEnd: 'Learn eligibility and application rules.',
    country: 'Country',
    region: 'Region',
    rebate: 'Rebate',
    apply: 'View Rebate Details',
    noRebates: 'No active rebates found in this category.',
    back: 'Back to Directory',
    breadcrumbCategories: 'Categories',
    home: 'Home'
  },
  'de-de': {
    titleSuffix: 'Rabatte weltweit — Leitfaden 2026',
    metaDescStart: 'Vergleichen Sie aktive Rabatte und grüne Energieanreize.',
    metaDescEnd: 'Erfahren Sie mehr über Berechtigung und Bewerbung.',
    country: 'Land',
    region: 'Region',
    rebate: 'Rabatt',
    apply: 'Rabattdetails anzeigen',
    noRebates: 'Keine aktiven Rabatte in dieser Kategorie gefunden.',
    back: 'Zurück zum Verzeichnis',
    breadcrumbCategories: 'Kategorien',
    home: 'Startseite'
  },
  'fr-fr': {
    titleSuffix: 'Subventions dans le monde — Guide 2026',
    metaDescStart: 'Comparez les subventions actives et incitations à l\'énergie verte.',
    metaDescEnd: 'Découvrez l\'éligibilité et l\'application.',
    country: 'Pays',
    region: 'Région',
    rebate: 'Subvention',
    apply: 'Voir les détails de la subvention',
    noRebates: 'Aucune subvention active trouvée dans cette catégorie.',
    back: 'Retour à l\'annuaire',
    breadcrumbCategories: 'Catégories',
    home: 'Accueil'
  }
}[lang as 'en-us' | 'de-de' | 'fr-fr'] || {
  titleSuffix: 'Rebates Worldwide — 2026 Guide',
  metaDescStart: 'Compare active rebates and green energy incentives.',
  metaDescEnd: 'Learn eligibility and application rules.',
  country: 'Country',
  region: 'Region',
  rebate: 'Rebate',
  apply: 'View Rebate Details',
  noRebates: 'No active rebates found in this category.',
  back: 'Back to Directory',
  breadcrumbCategories: 'Categories',
  home: 'Home'
};

// SEO Configuration
const siteUrl = 'https://incentivemapper.com';
const currentPath = `/${lang}/category/${category_slug}`;
const canonicalUrl = `${siteUrl}${currentPath}`;
const pageTitle = `${displayCategory} ${l10n.titleSuffix} | IncentiveMapper`;

const uniqueCountries = [...new Set(rebates.map(r => r.regions?.country_code?.toLowerCase() || 'us'))];
const countryCount = uniqueCountries.length;
const rebatesCount = rebates.length;

const metaDescription = `${l10n.metaDescStart} Browse ${rebatesCount} active ${displayCategory.toLowerCase()} programs across ${countryCount} countries. ${l10n.metaDescEnd}`;

// Generate hreflang alternates
const alternates = ['en-us', 'de-de', 'fr-fr'].map(l => ({
  hreflang: l,
  url: `${siteUrl}/${l}/category/${category_slug}`
}));
alternates.push({ hreflang: 'x-default', url: `${siteUrl}/en-us/category/${category_slug}` });

// Group rebates by country, then state, grouping repeated national programs
const processedGroupedRebates: Record<string, { national: Rebate[], states: Record<string, Rebate[]> }> = {};

// 1. Group raw rebates by country code
const countryGroups: Record<string, Rebate[]> = {};
rebates.forEach(r => {
  const country = r.regions?.country_code === 'gb' ? 'uk' : r.regions?.country_code?.toLowerCase() || 'us';
  if (!countryGroups[country]) {
    countryGroups[country] = [];
  }
  countryGroups[country].push(r);
});

// 2. Process each country's rebates
Object.entries(countryGroups).forEach(([countryCode, countryRebates]) => {
  // Count frequency of authority names
  const authorityCounts: Record<string, number> = {};
  countryRebates.forEach(r => {
    authorityCounts[r.authority_name] = (authorityCounts[r.authority_name] || 0) + 1;
  });

  const national: Rebate[] = [];
  const states: Record<string, Rebate[]> = {};
  const processedNames = new Set<string>();

  countryRebates.forEach(r => {
    const isRepeated = authorityCounts[r.authority_name] > 1;

    if (isRepeated) {
      if (processedNames.has(r.authority_name)) return;
      processedNames.add(r.authority_name);

      const matches = countryRebates.filter(m => m.authority_name === r.authority_name);
      
      // Sort matches alphabetically by city name to pick the first one as representative
      const sortedMatches = [...matches].sort((a, b) => {
        const cityA = a.regions?.city || '';
        const cityB = b.regions?.city || '';
        return cityA.localeCompare(cityB);
      });
      const representative = sortedMatches[0];

      const uniqueStates = [...new Set(matches.map(m => m.regions?.state_province).filter(Boolean))];
      const uniqueCities = [...new Set(matches.map(m => m.regions?.city).filter(Boolean))].sort((a, b) => (a as string).localeCompare(b as string));

      const cleanedDesc = cleanDescription(representative.description, representative.regions?.city, representative.regions?.state_province);
      const stateNameForSuffix = uniqueStates.length === 1 ? uniqueStates[0] : null;
      const newDesc = `${cleanedDesc}${getGroupedSuffix(uniqueCities.length, countryCode, stateNameForSuffix, lang || 'en-us')}`;

      const groupedCard = {
        ...representative,
        isGrouped: true,
        citiesList: uniqueCities,
        description: newDesc
      };

      if (uniqueStates.length === 1) {
        const stateName = uniqueStates[0];
        if (!states[stateName]) states[stateName] = [];
        states[stateName].push(groupedCard);
      } else {
        national.push(groupedCard);
      }
    } else {
      const stateName = r.regions?.state_province || 'National';
      if (!states[stateName]) states[stateName] = [];
      states[stateName].push({
        ...r,
        isGrouped: false
      });
    }
  });

  processedGroupedRebates[countryCode] = { national, states };
});

// Format currency
function formatValue(value: number, type: string, countryCode: string) {
  const code = countryCode.toLowerCase();
  const symbol = (code === 'de' || code === 'fr' || code === 'ie' || code === 'nl')
    ? '€'
    : (code === 'gb' || code === 'uk')
      ? '£'
      : (code === 'jp')
        ? '¥'
        : (code === 'nz')
          ? 'NZ$'
          : '$';
  if (type === 'percentage') {
    return `${value}%`;
  }
  if (type === 'per_watt') {
    return `${symbol}${value}/W`;
  }
  if (type === 'fixed') {
    return `${symbol}${value}`;
  }
  return `${symbol}${value} ${type}`;
}

// Format city listing text
function formatCitiesText(cities: string[]) {
  if (cities.length <= 4) {
    return `${cities.join(', ')}`;
  }
  return `${cities.slice(0, 3).join(', ')} +${cities.length - 3} more`;
}

// Clean description by removing location suffix
function cleanDescription(desc: string, city: string, state: string) {
  if (!desc) return desc;
  
  const suffixes = [
    ` in ${city}, ${state}.`,
    ` in ${city}, ${state}`,
    ` in ${city}.`,
    ` in ${city}`
  ];
  
  let cleaned = desc;
  for (const suffix of suffixes) {
    if (cleaned.endsWith(suffix)) {
      cleaned = cleaned.slice(0, -suffix.length);
      break;
    }
  }
  
  if (cleaned.endsWith('.')) {
    cleaned = cleaned.slice(0, -1);
  }
  
  return cleaned;
}

// Localized in-country preposition and name helper
function getInCountryPhrase(countryCode: string, lang: string): string {
  const code = countryCode.toLowerCase();
  if (lang === 'de-de') {
    const mapping: Record<string, string> = {
      us: 'in den USA',
      uk: 'in Großbritannien',
      de: 'in Deutschland',
      ca: 'in Kanada',
      au: 'in Australien',
      fr: 'in Frankreich'
    };
    return mapping[code] || `in ${code.toUpperCase()}`;
  }
  if (lang === 'fr-fr') {
    const mapping: Record<string, string> = {
      us: 'aux États-Unis',
      uk: 'au Royaume-Uni',
      de: 'en Allemagne',
      ca: 'au Canada',
      au: 'en Australie',
      fr: 'en France'
    };
    return mapping[code] || `en ${code.toUpperCase()}`;
  }
  const mapping: Record<string, string> = {
    us: 'in the United States',
    uk: 'in the United Kingdom',
    de: 'in Germany',
    ca: 'in Canada',
    au: 'in Australia',
    fr: 'in France'
  };
  return mapping[code] || `in ${code.toUpperCase()}`;
}

// Localized suffix helper
function getGroupedSuffix(citiesCount: number, countryCode: string, stateName: string | null, lang: string) {
  const locationPhrase = stateName ? `in ${stateName}` : getInCountryPhrase(countryCode, lang);
  
  if (lang === 'de-de') {
    if (stateName) {
      return `, bundeslandweit verfügbar in ${citiesCount} Städten ${locationPhrase}.`;
    }
    return `, landesweit verfügbar in ${citiesCount} Städten ${locationPhrase}.`;
  }
  if (lang === 'fr-fr') {
    if (stateName) {
      return `, disponible dans tout l'État dans ${citiesCount} villes ${locationPhrase}.`;
    }
    return `, disponible à l'échelle nationale dans ${citiesCount} villes ${locationPhrase}.`;
  }
  if (stateName) {
    return `, available state-wide across ${citiesCount} cities in ${stateName}.`;
  }
  return `, available nationwide across ${citiesCount} cities ${locationPhrase}.`;
}

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": l10n.home,
      "item": `${siteUrl}/${lang}`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": t.nav.directory,
      "item": `${siteUrl}/${lang}/directory`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": displayCategory,
      "item": canonicalUrl
    }
  ]
};

// ItemList Schema for rebates
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `${displayCategory} Rebates`,
  "numberOfItems": rebates.length,
  "itemListElement": rebates.map((r, idx) => ({
    "@type": "ListItem",
    "position": idx + 1,
    "url": `${siteUrl}/${lang}/rebate/${r.slug}`
  }))
};
import ThemeFonts from '../../../components/ThemeFonts.astro';
---

<!DOCTYPE html>
<html lang={lang} data-theme="sage-minimalist">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <title>{pageTitle}</title>
  <meta name="description" content={metaDescription} />

  <!-- Canonical & hreflang Alternates -->
  <link rel="canonical" href={canonicalUrl} />
  {alternates.map(alt => (
    <link rel="alternate" hreflang={alt.hreflang} href={alt.url} />
  ))}

  <ClientRouter />
  <script is:inline>
    // Theme Management
    const savedTheme = localStorage.getItem('theme') || 'sage-minimalist';
    document.documentElement.setAttribute('data-theme', savedTheme);

    document.addEventListener('astro:page-load', () => {
      const activeTheme = localStorage.getItem('theme') || 'sage-minimalist';
      document.documentElement.setAttribute('data-theme', activeTheme);
    });
  </script>
  
  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {rebates.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  )}

  
  <ThemeFonts />
  <Analytics />
</head>
<body class="min-h-screen flex flex-col justify-between">
  
  <Navbar lang={lang} />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-16 flex-grow w-full">
    <!-- Breadcrumbs UI -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-xs text-[var(--text-muted)] font-medium flex-wrap">
        <li>
          <a href={`/${lang}`} class="hover:text-[var(--text-main)] transition-colors">{l10n.home}</a>
        </li>
        <li class="flex items-center gap-2">
          <span>/</span>
          <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.directory}</a>
        </li>
        <li class="flex items-center gap-2">
          <span>/</span>
          <span class="text-[var(--text-main)] font-semibold" aria-current="page">{displayCategory}</span>
        </li>
      </ol>
    </nav>

    <div class="mb-10 text-center md:text-left">
      <h1 class="text-4xl font-black tracking-tight text-[var(--text-main)] mb-3 leading-tight">{displayCategory} {lang === 'de-de' ? 'Rabatte & Anreize' : lang === 'fr-fr' ? 'Subventions' : 'Rebates & Incentives'}</h1>
      <p class="text-lg text-[var(--text-muted)]">{lang === 'de-de' ? `Durchsuchen Sie ${rebatesCount} aktive Programme in ${countryCount} Ländern.` : lang === 'fr-fr' ? `Parcourez ${rebatesCount} programmes actifs dans ${countryCount} pays.` : `Explore ${rebatesCount} active programs across ${countryCount} countries.`}</p>
    </div>

    <!-- Rebates List Grouped by Country and State -->
    {rebates.length === 0 ? (
      <div class="bg-[var(--bg-secondary)] border border-[var(--color-border)] rounded-2xl p-8 text-center text-[var(--text-muted)]">
        {l10n.noRebates}
      </div>
    ) : (
      <div class="space-y-10">
        {Object.entries(processedGroupedRebates).map(([countryCode, countryData]) => {
          const meta = COUNTRY_METADATA[countryCode] || { name: countryCode.toUpperCase(), flag: '🌐' };
          const hasNational = countryData.national.length > 0;

          return (
            <div class="bg-[var(--bg-secondary)] border border-[var(--color-border)] rounded-3xl p-6 md:p-8 shadow-sm">
              <div class="flex items-center gap-3 mb-6 pb-4 border-b border-[var(--color-border)]">
                <span class="text-3xl" role="img" aria-label={meta.name}>{meta.flag}</span>
                <h2 class="text-2xl font-bold text-[var(--text-main)]">{meta.name}</h2>
              </div>

              <div class="space-y-8">
                {/* 1. National Programs */}
                {hasNational && (
                  <div>
                    <h3 class="text-xs font-bold uppercase tracking-wider text-[var(--text-muted)] mb-4">
                      {lang === 'de-de' ? 'Nationale Programme' : lang === 'fr-fr' ? 'Programmes Nationaux' : 'National Programs'}
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                      {countryData.national.map((rebate) => (
                        <div class="bg-[var(--bg-primary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] rounded-2xl p-5 flex flex-col justify-between shadow-sm hover:shadow transition-all duration-300">
                          <div>
                            <div class="flex justify-between items-start gap-2 mb-2">
                              <h4 class="font-extrabold text-[var(--text-main)] leading-snug">
                                {rebate.authority_name}
                              </h4>
                              <span class="text-xs font-bold px-2 py-0.5 rounded bg-[var(--bg-secondary)] border border-[var(--color-border)] text-[var(--text-muted)] whitespace-nowrap">
                                {formatValue(rebate.incentive_value, rebate.incentive_type, rebate.regions?.country_code)}
                              </span>
                            </div>
                            <p class="text-xs text-[var(--text-muted)] mb-4 line-clamp-3">
                              {rebate.description}
                            </p>
                          </div>
                          <div class="flex justify-between items-center pt-2 mt-auto border-t border-[var(--color-border)]/50">
                            <span class="text-[10px] font-semibold text-[var(--text-muted)]">
                              📍 Available in: {formatCitiesText(rebate.citiesList)}
                            </span>
                            <a 
                              href={`/${lang}/rebate/${rebate.slug}`} 
                              class="text-xs font-bold text-[var(--color-accent)] hover:underline transition-all"
                            >
                              {l10n.apply} →
                            </a>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {/* 2. State-Specific Programs */}
                {Object.entries(countryData.states).map(([stateName, items]) => (
                  <div>
                    <h3 class="text-xs font-bold uppercase tracking-wider text-[var(--text-muted)] mb-4">
                      {stateName}
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                      {items.map((rebate) => {
                        const countrySlug = countryCode;
                        const stateSlug = rebate.regions?.state_province?.toLowerCase().replace(/\s+/g, '-');
                        return (
                          <div class="bg-[var(--bg-primary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] rounded-2xl p-5 flex flex-col justify-between shadow-sm hover:shadow transition-all duration-300">
                            <div>
                              <div class="flex justify-between items-start gap-2 mb-2">
                                <h4 class="font-extrabold text-[var(--text-main)] leading-snug">
                                  {rebate.authority_name}
                                </h4>
                                <span class="text-xs font-bold px-2 py-0.5 rounded bg-[var(--bg-secondary)] border border-[var(--color-border)] text-[var(--text-muted)] whitespace-nowrap">
                                  {formatValue(rebate.incentive_value, rebate.incentive_type, rebate.regions?.country_code)}
                                </span>
                              </div>
                              <p class="text-xs text-[var(--text-muted)] mb-4 line-clamp-3">
                                {rebate.description}
                              </p>
                            </div>
                            <div class="flex justify-between items-center pt-2 mt-auto border-t border-[var(--color-border)]/50">
                              {rebate.isGrouped ? (
                                <span class="text-[10px] font-semibold text-[var(--text-muted)]">
                                  📍 Available in: {formatCitiesText(rebate.citiesList)}
                                </span>
                              ) : (
                                <a 
                                  href={`/${lang}/directory/${countrySlug}/${stateSlug}`} 
                                  class="text-[10px] font-semibold text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors"
                                >
                                  📍 {rebate.regions?.city}
                                </a>
                              )}
                              <a 
                                href={`/${lang}/rebate/${rebate.slug}`} 
                                class="text-xs font-bold text-[var(--color-accent)] hover:underline transition-all"
                              >
                                {l10n.apply} →
                              </a>
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    )}

    <div class="mt-12 text-center">
      <a 
        href={`/${lang}/directory`} 
        class="inline-flex items-center gap-2 bg-[var(--bg-secondary)] hover:bg-[var(--bg-primary)] text-[var(--text-main)] border border-[var(--color-border)] hover:border-[var(--text-main)] font-semibold px-6 py-3 rounded-full shadow-sm transition-all duration-300"
      >
        ← {l10n.back}
      </a>
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-border)] bg-[var(--bg-primary)] py-8 text-center text-xs text-[var(--text-muted)]">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>{t.footer.copyright}</div>
      <div class="flex gap-4 flex-wrap justify-center font-medium">
        <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)]">{t.footer.directory}</a>
        <a href={`/${lang}/search`} class="hover:text-[var(--text-main)]">{t.footer.search}</a>
        <a href={`/${lang}/compare`} class="hover:text-[var(--text-main)]">{t.footer.compare}</a>
        <a href={`/${lang}/compliance`} class="hover:text-[var(--text-main)]">{t.footer.compliance}</a>
        <a href={`/${lang}/blog`} class="hover:text-[var(--text-main)]">{t.footer.blog}</a>
        <a href={`/${lang}/privacy`} class="hover:text-[var(--text-main)]">{t.footer.privacy}</a>
