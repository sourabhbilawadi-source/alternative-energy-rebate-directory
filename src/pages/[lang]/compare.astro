---
import '../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import ComparisonEngine from '../../components/compare/ComparisonEngine';
import { useTranslations } from '../../lib/i18n';
import Analytics from '../../components/Analytics.astro';

export async function getStaticPaths() {
  return [
    { params: { lang: 'en-us' } },
    { params: { lang: 'de-de' } },
    { params: { lang: 'fr-fr' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang || 'en-us');
import Navbar from '../../components/Navbar.astro';
import { supabase } from '../../lib/supabase';

const siteUrl = 'https://incentivemapper.com';
const canonicalUrl = `${siteUrl}/${lang}/compare`;
const alternates = ['en-us', 'de-de', 'fr-fr'].map(l => ({
  hreflang: l,
  url: `${siteUrl}/${l}/compare`
}));

let serverRebates = [];
if (supabase) {
  try {
    const { data } = await supabase
      .from('rebates')
      .select(`
        id,
        authority_name,
        technology_category,
        incentive_value,
        incentive_type,
        max_limit,
        regions (
          id,
          country_code,
          state_province,
          city,
          postal_code
        )
      `)
      .eq('is_active', true);
    if (data) {
      serverRebates = data;
    }
  } catch (err) {
    console.error('Failed to query rebates for Compare page:', err);
  }
}
import ThemeFonts from '../../components/ThemeFonts.astro';
---

<!DOCTYPE html>
<html lang={lang} data-theme="sage-minimalist">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <title>{t.compare.title} | IncentiveMapper</title>
  <meta name="description" content="Compare alternative energy utility rates, solar resource coefficients, and rebate payback timelines side by side." />

  <!-- Canonical & hreflang Alternate Declarations -->
  <link rel="canonical" href={canonicalUrl} />
  {alternates.map(alt => (
    <link rel="alternate" hreflang={alt.hreflang} href={alt.url} />
  ))}

  <!-- Open Graph / Facebook Preview Metadata -->
  <meta property="og:title" content={`${t.compare.title} | IncentiveMapper`} />
  <meta property="og:description" content="Compare alternative energy utility rates, solar resource coefficients, and rebate payback timelines side by side." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://incentivemapper.com/${lang}/compare`} />
  <meta property="og:image" content="https://incentivemapper.com/og-preview.png" />

  <!-- Twitter Card Metadata -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${t.compare.title} | IncentiveMapper`} />
  <meta name="twitter:description" content="Compare alternative energy utility rates, solar resource coefficients, and rebate payback timelines side by side." />
  <meta name="twitter:image" content="https://incentivemapper.com/og-preview.png" />
  <ClientRouter />
  <script is:inline>
    // 1. Immediately apply saved theme to avoid flashing
    const savedTheme = localStorage.getItem('theme') || 'sage-minimalist';
    document.documentElement.setAttribute('data-theme', savedTheme);

    // 2. Re-bind theme on Astro page loads (ClientRouter compatibility)
    document.addEventListener('astro:page-load', () => {
      const activeTheme = localStorage.getItem('theme') || 'sage-minimalist';
      document.documentElement.setAttribute('data-theme', activeTheme);
    });
  </script>
  
  <ThemeFonts />
  <Analytics />
</head>
<body class="min-h-screen flex flex-col justify-between">
  <Navbar lang={lang} />


  <!-- Main Content -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16 flex-grow" transition:animate="fade">
    <div class="text-center md:text-left mb-8">
      <h1 class="text-4xl font-extrabold tracking-tight mb-3 text-[var(--text-main)]">{t.compare.title}</h1>
      <p class="text-lg text-[var(--text-muted)]">{t.compare.subtitle}</p>
    </div>

    <!-- Comparison Engine React Island -->
    <ComparisonEngine client:load lang={lang} databaseRebates={serverRebates} />
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-border)] bg-[var(--bg-primary)] py-8 text-center text-xs text-[var(--text-muted)]">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>{t.footer.copyright}</div>
      <div class="flex gap-4 flex-wrap justify-center">
        <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)]">{t.footer.directory}</a>
        <a href={`/${lang}/search`} class="hover:text-[var(--text-main)]">{t.footer.search}</a>
        <a href={`/${lang}/compare`} class="hover:text-[var(--text-main)] font-semibold">{t.footer.compare}</a>
        <a href={`/${lang}/compliance`} class="hover:text-[var(--text-main)]">{t.footer.compliance}</a>
                <a href={`/${lang}/blog`} class="hover:text-[var(--text-main)]">{t.footer.blog}</a>
<a href={`/${lang}/privacy`} class="hover:text-[var(--text-main)]">{t.footer.privacy}</a>
        <a href={`/${lang}/terms`} class="hover:text-[var(--text-main)]">{t.footer.terms}</a>
      </div>
    </div>
  </footer>
</body>
</html>
