---
import '../../../../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import RebateCalculator, { type DbRebate } from '../../../../../components/calculator/RebateCalculator';
import SmeHub from '../../../../../components/calculator/SmeHub';
import { supabase } from '../../../../../lib/supabase';
import { useTranslations } from '../../../../../lib/i18n';
import Analytics from '../../../../../components/Analytics.astro';
import { regionsData } from '../../../../../data/regions';

// Enable static pre-rendering with dynamic paths from database (with static fallbacks)
export async function getStaticPaths() {
  const langs = ['en-us', 'de-de', 'fr-fr'];
  let citiesList = regionsData.map(r => ({
    country: r.countryCode,
    state: r.stateSlug,
    city: r.citySlug
  }));

  if (supabase) {
    try {
      const { data, error } = await supabase
        .from('regions')
        .select('country_code, state_province, state_slug, city');
      
      if (error) {
        console.error("DEBUG: Supabase query error in [city].astro getStaticPaths:", error);
      }
      
      if (data && data.length > 0) {
        const dbCities = data.map(r => ({
          country: r.country_code === 'gb' ? 'uk' : r.country_code.toLowerCase(),
          state: r.state_slug || r.state_province.toLowerCase().replace(/\s+/g, '-'),
          city: r.city.toLowerCase().replace(/\s+/g, '-')
        }));
        
        const seen = new Set();
        for (const c of citiesList) {
          seen.add(`${c.country}:${c.state}:${c.city}`);
        }
        for (const dbc of dbCities) {
          const key = `${dbc.country}:${dbc.state}:${dbc.city}`;
          if (!seen.has(key)) {
            seen.add(key);
            citiesList.push(dbc);
          }
        }
      }
    } catch (err) {
      console.error('Failed to query regions for static paths. Using fallbacks:', err);
    }
  }

  const paths = [];
  for (const lang of langs) {
    for (const item of citiesList) {
      paths.push({ params: { lang, ...item } });
    }
  }
  return paths;
}

const { lang, country, state, city } = Astro.params;
const t = useTranslations(lang || 'en-us');

const match = regionsData.find(
  r => r.countryCode === country && r.stateSlug === state && r.citySlug === city
);

// Format names for display
const displayCity = match?.cityName || (city ? city.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ') : '');
const displayState = match?.stateName || (state ? state.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ') : '');
const displayCountry = match?.countryName || (country ? country.toUpperCase() : '');

// Localized mock energy rates and solar resources based on state
const getLocalSpecs = () => {
  const DEFAULT_FALLBACK = {
    gridRate: 0.32,
    sunHours: 1050,
    gridEmissions: 0.40,
    costPerWatt: 3.40,
    incentives: {
      federalTaxCreditPct: 0.0,
      stateRebate: 1200,
      utilityRebate: 300
    }
  };

  if (!match) {
    return DEFAULT_FALLBACK;
  }

  return {
    gridRate: match.gridRate,
    sunHours: match.sunHours,
    gridEmissions: match.gridEmissions,
    costPerWatt: match.costPerWatt,
    incentives: {
      federalTaxCreditPct: match.federalTaxCreditPct,
      stateRebate: match.stateRebate,
      utilityRebate: match.utilityRebate
    }
  };
};

const presets = getLocalSpecs();
let localSpecs = { ...presets };

// Query dynamic regional rebates & energy specifications from Supabase
let dbRebates: DbRebate[] = [];
let dbPostalCode = '';

if (supabase) {
  try {
    const { data: regionData } = await supabase
      .from('regions')
      .select('id, grid_rate, sun_hours, grid_emissions, cost_per_watt, postal_code')
      .eq('country_code', country === 'uk' ? 'gb' : (country || 'us').toLowerCase())
      .eq('state_slug', state)
      .ilike('city', (city || '').replace(/-/g, ' '))
      .limit(1)
      .maybeSingle();

    if (regionData) {
      if (regionData.postal_code) dbPostalCode = regionData.postal_code;
      // Use database specs if available, otherwise fall back to presets
      if (regionData.grid_rate !== null && regionData.grid_rate !== undefined) localSpecs.gridRate = Number(regionData.grid_rate);
      if (regionData.sun_hours !== null && regionData.sun_hours !== undefined) localSpecs.sunHours = Number(regionData.sun_hours);
      if (regionData.grid_emissions !== null && regionData.grid_emissions !== undefined) localSpecs.gridEmissions = Number(regionData.grid_emissions);
      if (regionData.cost_per_watt !== null && regionData.cost_per_watt !== undefined) localSpecs.costPerWatt = Number(regionData.cost_per_watt);

      const { data: rebatesData } = await supabase
        .from('rebates')
        .select('*')
        .eq('region_id', regionData.id)
        .eq('is_active', true);

      if (rebatesData) {
        dbRebates = rebatesData;
      }
    }
  } catch (err) {
    console.error('Failed to query Supabase database records. Fallback enabled:', err);
  }
}

// SEO URLs
const siteUrl = 'https://incentivemapper.com';
const currentPath = `/${lang}/directory/${country}/${state}/${city}`;
const canonicalUrl = `${siteUrl}${currentPath}`;

// Generate hreflang alternates
const languages = ['en-us', 'de-de', 'fr-fr'];
const alternates = languages.map(l => ({
  hreflang: l,
  url: `${siteUrl}/${l}/directory/${country}/${state}/${city}`
}));
alternates.push({ hreflang: 'x-default', url: `${siteUrl}/en-us/directory/${country}/${state}/${city}` });

// Resolve unique category types for local page links
const cityCategories = dbRebates ? [...new Set(dbRebates.map(r => r.technology_category))] : [];

// JSON-LD Schemas
const governmentBenefitSchema = {
  "@context": "https://schema.org",
  "@type": "GovernmentBenefit",
  "name": `Alternative Energy Incentives in ${displayCity}, ${displayState}`,
  "description": `Discover regional rebates, federal tax credits, and utility incentives for solar energy, battery storage, and heat pumps in ${displayCity}.`,
  "provider": {
    "@type": "GovernmentOrganization",
    "name": "Local Energy Efficiency Agency"
  },
  "serviceArea": {
    "@type": "AdministrativeArea",
    "name": displayState
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Alternative Energy Rebate Directory",
  "url": siteUrl,
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${siteUrl}/search?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": lang === 'de-de' ? 'Startseite' : lang === 'fr-fr' ? 'Accueil' : 'Home',
      "item": `${siteUrl}/${lang}`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": displayCountry,
      "item": `${siteUrl}/${lang}/directory/${country}`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": displayState,
      "item": `${siteUrl}/${lang}/directory/${country}/${state}`
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": displayCity,
      "item": canonicalUrl
    }
  ]
};

// Dynamic SEO Metadata Sizing Calculation
const standardSize = 6; // kW
const capCost = standardSize * 1000 * (localSpecs.costPerWatt || 3.40);
const fedCredit = capCost * (localSpecs.incentives?.federalTaxCreditPct || 0.0);
const stRebate = localSpecs.incentives?.stateRebate || 0;
const utRebate = localSpecs.incentives?.utilityRebate || 0;
const netCost = Math.max(0, capCost - (fedCredit + stRebate + utRebate));
const annualGen = standardSize * (localSpecs.sunHours || 1050);
const annualSavings = annualGen * (localSpecs.gridRate || 0.32);
const estimatedPayback = annualSavings > 0 ? (netCost / annualSavings) : null;
const paybackText = estimatedPayback ? estimatedPayback.toFixed(1) : 'under 5';

// Localized Title & Description
const getCurrencySymbol = (code: string) => {
  const c = code?.toLowerCase();
  if (c === 'de') return '€';
  if (c === 'uk') return '£';
  if (c === 'au') return 'A$';
  if (c === 'ca') return 'C$';
  return '$';
};
const currencySymbol = getCurrencySymbol(country);

const isUs = (country || "").toLowerCase() === "us";
let seoTitle = '';
let seoDescription = '';
let h1Title = '';
let introParagraph = '';
const fedPctText = Math.round((localSpecs.incentives?.federalTaxCreditPct || 0.0) * 100);
const rateText = (localSpecs.gridRate || 0.32).toFixed(2);
const currentYear = 2026;

if (lang === 'de-de') {
  seoTitle = `${displayCity}, ${displayState} Solarförderung 2026 — Berechnen Sie Ihre Amortisationszeit | IncentiveMapper`;
  seoDescription = isUs 
    ? `Sparen Sie bei Solarstrom in ${displayCity}, ${displayState} mit Stromtarifen von ${currencySymbol}${rateText}/kWh. Berechnen Sie Ihre Amortisationszeit, Solareinsparungen und lokale Solarförderungen!`
    : `Sparen Sie bei Solarstrom in ${displayCity}, ${displayState} mit ${fedPctText}% Bundessteuergutschrift und Stromtarifen von ${currencySymbol}${rateText}/kWh. Geschätzte Amortisation: ${paybackText} Jahre. Berechnen Sie Ihren ROI!`;
  h1Title = `${displayCity}, ${displayState} Solar- & Energieförderung ${currentYear}`;
  introParagraph = `Mit einem durchschnittlichen Strompreis von ${currencySymbol}${rateText}/kWh und ${localSpecs.sunHours} Sonnenstunden pro Jahr amortisiert sich eine typische 6-kW-Solaranlage in ${displayCity}, ${displayState} in ca. ${paybackText} Jahren. Entdecken Sie unten alle aktiven Fördermittel und berechnen Sie Ihre Rendite!`;
} else if (lang === 'fr-fr') {
  seoTitle = `Subventions Solaires ${displayCity}, ${displayState} 2026 — Calculez Votre Période d'Amortissement | IncentiveMapper`;
  seoDescription = isUs
    ? `Économisez sur l'énergie solaire à ${displayCity}, ${displayState} avec des tarifs d'électricité de ${currencySymbol}${rateText}/kWh. Calculez votre amortissement, vos économies et vos subventions locales!`
    : `Économisez sur l'énergie solaire à ${displayCity}, ${displayState} avec un crédit d'impôt fédéral de ${fedPctText}% et des tarifs de ${currencySymbol}${rateText}/kWh. Période d'amortissement estimée : ${paybackText} ans.`;
  h1Title = `${displayCity}, ${displayState} : Subventions Solaires & Énergétiques ${currentYear}`;
  introParagraph = `Avec un tarif moyen de ${currencySymbol}${rateText}/kWh et ${localSpecs.sunHours} heures d'ensoleillement par an, une installation solaire type de 6 kW à ${displayCity}, ${displayState} s'amortit en environ ${paybackText} ans. Découvrez toutes les aides et simulez votre ROI ci-dessous !`;
} else {
  // Default to English
  seoTitle = `${displayCity}, ${displayState} Solar Rebates 2026 — Calculate Your Payback Period | IncentiveMapper`;
  seoDescription = isUs
    ? `Save on solar in ${displayCity}, ${displayState} with local utility rates of ${currencySymbol}${rateText}/kWh. Calculate your estimated payback, solar savings, and active rebates today!`
    : `Save on solar in ${displayCity}, ${displayState} with a ${fedPctText}% federal tax credit and utility rates of ${currencySymbol}${rateText}/kWh. Estimated payback period: ${paybackText} years. Calculate your solar ROI today!`;
  h1Title = `${displayCity}, ${displayState} Solar & Energy Rebates ${currentYear}`;
  introParagraph = `With average local utility rates of ${currencySymbol}${rateText}/kWh and ${localSpecs.sunHours} peak sun hours per year, a typical 6 kW solar installation in ${displayCity}, ${displayState} has an estimated payback period of ${paybackText} years. Explore active incentives and calculate your custom ROI below.`;
}

// FAQ Schema definition
let faqSchema = {};
const annualGenFormatted = Math.round(annualGen).toLocaleString(lang === 'de-de' ? 'de-DE' : lang === 'fr-fr' ? 'fr-FR' : 'en-US');
const annualSavingsFormatted = Math.round(annualSavings).toLocaleString(lang === 'de-de' ? 'de-DE' : lang === 'fr-fr' ? 'fr-FR' : 'en-US');

if (lang === 'de-de') {
  faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": `Wie viel kann ich in ${displayCity} mit Solarstrom sparen?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Durch die Installation von Solarmodulen in ${displayCity} können Sie Ihre Stromkosten erheblich senken. Bei einem lokalen Stromtarif von ${currencySymbol}${rateText}/kWh und durchschnittlich ${localSpecs.sunHours} Sonnenstunden pro Jahr erzeugt eine typische 6-kW-Solaranlage jährlich etwa ${annualGenFormatted} kWh Strom. Dies entspricht einer geschätzten Ersparnis von ${currencySymbol}${annualSavingsFormatted} im ersten Jahr.`
        }
      },
      {
        "@type": "Question",
        "name": `Welche Solarförderungen gibt es in ${displayState}?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `In ${displayState} können Sie von verschiedenen Anreizen profitieren. Dazu gehören eine Bundessteuergutschrift von ${fedPctText}%, staatliche Zuschüsse von bis zu ${currencySymbol}${stRebate} und Fördermittel von Versorgungsunternehmen von bis zu ${currencySymbol}${utRebate}. In unserer Datenbank sind für diese Region derzeit ${dbRebates.length} aktive Förderprogramme registriert.`
        }
      },
      {
        "@type": "Question",
        "name": `Wie lange ist die Amortisationszeit für Solarstrom in ${displayCity}?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Die geschätzte Amortisationszeit für Solaranlagen in ${displayCity}, ${displayState} beträgt etwa ${paybackText} Jahre. Dies basiert auf den Nettosystemkosten nach Abzug aller anwendbaren Förderungen (wie der ${fedPctText}% Bundessteuergutschrift, staatlichen Zuschüssen von ${currencySymbol}${stRebate} und Zuschüssen von Versorgungsbetrieben von ${currencySymbol}${utRebate}) im Vergleich zu Ihren jährlichen Stromeinsparungen von ${currencySymbol}${annualSavingsFormatted}.`
        }
      },
      {
        "@type": "Question",
        "name": `Gibt es in ${displayCity} Net Metering (Netzeinspeisung)?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Ja, Netzeinspeisung oder entsprechende Einspeisevergütungen sind in ${displayCity}, ${displayState} über die lokalen Netzbetreiber verfügbar. Dadurch können Sie überschüssigen Solarstrom in das öffentliche Netz einspeisen und erhalten dafür Gutschriften oder Vergütungen, die Ihre Energiekosten weiter senken.`
        }
      }
    ]
  };
} else if (lang === 'fr-fr') {
  faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": `Combien puis-je économiser grâce au solaire à ${displayCity} ?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `L'installation de panneaux solaires à ${displayCity} permet de réduire considérablement vos factures d'électricité. Avec un tarif d'électricité local de ${currencySymbol}${rateText}/kWh et une moyenne de ${localSpecs.sunHours} heures d'ensoleillement par an, un système solaire standard de 6 kW produit environ ${annualGenFormatted} kWh par an, ce qui représente une économie estimée à ${currencySymbol}${annualSavingsFormatted} la première année.`
        }
      },
      {
        "@type": "Question",
        "name": `Quelles subventions solaires sont disponibles en ${displayState} ?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `En ${displayState}, vous pouvez bénéficier de plusieurs incitations financières : un crédit d'impôt de ${fedPctText}%, des subventions de l'État allant jusqu'à ${currencySymbol}${stRebate}, et des aides des fournisseurs d'énergie de ${currencySymbol}${utRebate}. Actuellement, ${dbRebates.length} programmes d'aides actifs sont enregistrés dans notre base de données pour cette région.`
        }
      },
      {
        "@type": "Question",
        "name": `Quelle est la durée d'amortissement des panneaux solaires à ${displayCity} ?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `La période d'amortissement estimée pour une installation solaire à ${displayCity}, ${displayState} est d'environ ${paybackText} ans. Ce calcul prend en compte le coût net du système après déduction du crédit d'impôt de ${fedPctText}% et des subventions (d'une valeur de ${currencySymbol}${stRebate} pour l'État et ${currencySymbol}${utRebate} pour le fournisseur d'énergie), divisé par vos économies annuelles d'électricité de ${currencySymbol}${annualSavingsFormatted}.`
        }
      },
      {
        "@type": "Question",
        "name": `Est-ce que le net metering (facturation nette) est disponible à ${displayCity} ?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Oui, le net metering ou des dispositifs d'achat de l'électricité (comme l'obligation d'achat) sont généralement disponibles à ${displayCity}, ${displayState} via les distributeurs d'énergie locaux. Cela vous permet d'injecter votre surplus d'électricité sur le réseau en échange de crédits ou de tarifs de rachat pour réduire vos coûts.`
        }
      }
    ]
  };
} else {
  faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": `How much can I save on solar in ${displayCity}?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `By installing solar panels in ${displayCity}, you can save significantly on your electricity bills. With a local utility rate of ${currencySymbol}${rateText}/kWh and an average of ${localSpecs.sunHours} peak sun hours annually, a standard 6 kW solar system generates approximately ${annualGenFormatted} kWh of electricity per year. This translates to an estimated first-year savings of ${currencySymbol}${annualSavingsFormatted}.`
        }
      },
      {
        "@type": "Question",
        "name": `What solar rebates are available in ${displayState}?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `In ${displayState}, you can take advantage of various solar incentives. These include a federal tax credit of ${fedPctText}%, local state rebates of up to ${currencySymbol}${stRebate}, and utility rebates of up to ${currencySymbol}${utRebate}. There are also ${dbRebates.length} active rebate programs registered in our database for this region.`
        }
      },
      {
        "@type": "Question",
        "name": `How long is the solar payback period in ${displayCity}?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `The estimated solar payback period in ${displayCity}, ${displayState} is approximately ${paybackText} years. This is calculated based on the net system cost after applying the ${fedPctText}% federal tax credit, state rebates of ${currencySymbol}${stRebate}, and utility rebates of ${currencySymbol}${utRebate}, divided by your projected annual electricity savings of ${currencySymbol}${annualSavingsFormatted}.`
        }
      },
      {
        "@type": "Question",
        "name": `Does ${displayCity} have net metering?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Yes, net metering or export billing options are typically available in ${displayCity}, ${displayState} through local utility providers. This program allows you to send surplus electricity produced by your solar panels back to the power grid, earning utility bill credits that offset your energy costs during periods of low solar generation.`
        }
      }
    ]
  };
}
import Navbar from '../../../../../components/Navbar.astro';
import ThemeFonts from '../../../../../components/ThemeFonts.astro';
---

<!DOCTYPE html>
<html lang={lang} data-theme="sage-minimalist">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <title>{seoTitle}</title>
  <meta name="description" content={seoDescription} />

  <!-- Open Graph / Facebook Preview Metadata -->
  <meta property="og:title" content={seoTitle} />
  <meta property="og:description" content={seoDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content="https://incentivemapper.com/og-preview.png" />
  <meta property="og:locale" content={lang.replace('-', '_')} />

  <!-- Twitter Card Metadata -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={seoTitle} />
  <meta name="twitter:description" content={seoDescription} />
  <meta name="twitter:image" content="https://incentivemapper.com/og-preview.png" />
  
  <!-- Canonical & hreflang Alternate Declarations -->
  <link rel="canonical" href={canonicalUrl} />
  {alternates.map(alt => (
    <link rel="alternate" hreflang={alt.hreflang} href={alt.url} />
  ))}

  <!-- JSON-LD Structured Schema Maps -->
  <script type="application/ld+json" set:html={JSON.stringify(governmentBenefitSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Astro View Transitions -->
  <ClientRouter />
  <script is:inline>
    // 1. Immediately apply saved theme to avoid flashing
    const savedTheme = localStorage.getItem('theme') || 'sage-minimalist';
    document.documentElement.setAttribute('data-theme', savedTheme);

    // 2. Re-bind theme on Astro page loads (ClientRouter compatibility)
    document.addEventListener('astro:page-load', () => {
      const activeTheme = localStorage.getItem('theme') || 'sage-minimalist';
      document.documentElement.setAttribute('data-theme', activeTheme);
    });
  </script>
  
  <ThemeFonts />
  <Analytics />
</head>
<body class="min-h-screen pb-16">
  <!-- Persistent Header with Navigation -->
  <Navbar lang={lang} />

  <!-- Main Content Layout -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8" transition:animate="slide">
    <!-- Breadcrumbs -->
    <nav class="text-sm text-[var(--text-muted)] mb-4 flex items-center gap-2 flex-wrap" aria-label="Breadcrumb">
      <a href={`/${lang}`} class="hover:text-[var(--text-main)] transition-colors">{lang === 'de-de' ? 'Startseite' : lang === 'fr-fr' ? 'Accueil' : 'Home'}</a>
      <span>/</span>
      <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)] transition-colors capitalize">{t.nav.directory}</a>
      <span>/</span>
      <a href={`/${lang}/directory/${country}`} class="hover:text-[var(--text-main)] transition-colors uppercase">{country}</a>
      <span>/</span>
      <a href={`/${lang}/directory/${country}/${state}`} class="hover:text-[var(--text-main)] transition-colors capitalize">{displayState}</a>
      <span>/</span>
      <span class="text-[var(--text-main)] font-semibold capitalize" aria-current="page">{displayCity}</span>
    </nav>

    <!-- Page Title Header Section -->
    <div class="mb-10 text-center md:text-left">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4 leading-tight">{h1Title}</h1>
      <p class="text-lg text-[var(--text-muted)] max-w-3xl">
        {introParagraph}
      </p>
      {cityCategories.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2 justify-center md:justify-start items-center">
          <span class="text-xs font-bold text-[var(--text-muted)] uppercase tracking-wider mr-1">
            {lang === 'de-de' ? 'Kategorien:' : lang === 'fr-fr' ? 'Catégories:' : 'Categories:'}
          </span>
          {cityCategories.map(cat => {
            const slug = cat.toLowerCase().replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-').replace(/-+/g, '-');
            return (
              <a 
                href={`/${lang}/category/${slug}`}
                class="text-xs font-bold px-3 py-1 rounded-full bg-[var(--bg-secondary)] hover:bg-[var(--bg-primary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] text-[var(--text-muted)] hover:text-[var(--text-main)] transition-all"
              >
                🔍 {cat}
              </a>
            );
          })}
        </div>
      )}
    </div>

    <!-- Tab Section for Residential vs SME -->
    <div class="mb-8 border-b border-[var(--color-border)] flex gap-6">
      <button 
        id="btn-residential" 
        class="pb-3 text-lg font-bold border-b-2 border-[var(--color-accent)] text-[var(--text-main)] focus:outline-none"
      >
        {lang === 'de-de' ? 'Wohnrechner' : lang === 'fr-fr' ? 'Simulateur Résidentiel' : 'Residential Calculator'}
      </button>
      <button 
        id="btn-sme" 
        class="pb-3 text-lg font-medium text-[var(--text-muted)] hover:text-[var(--text-main)] focus:outline-none border-b-2 border-transparent"
      >
        {lang === 'de-de' ? 'KMU-Dekarbonisierungszentrum' : lang === 'fr-fr' ? 'Espace Décarbonation PME' : 'SME Decarbonization Hub'}
      </button>
    </div>

    <!-- Active Panels -->
    <div id="panel-residential" class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start animate-fade-in">
      <!-- Calculator React Island -->
      <div class="lg:col-span-12">
        <RebateCalculator 
          client:visible 
          defaultPostalCode={dbPostalCode}
          defaultGridRate={localSpecs.gridRate}
          defaultSunHours={localSpecs.sunHours}
          defaultGridEmissions={localSpecs.gridEmissions}
          defaultCostPerWatt={localSpecs.costPerWatt}
          federalTaxCreditPct={localSpecs.incentives.federalTaxCreditPct}
          stateRebate={localSpecs.incentives.stateRebate}
          utilityRebate={localSpecs.incentives.utilityRebate}
          city={displayCity}
          state={displayState}
          dbRebates={dbRebates}
          lang={lang}
          regionEntry={match}
        >
          <!-- Skeleton Loading Fallback to prevent Cumulative Layout Shift (CLS) -->
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 bg-[var(--bg-secondary)] border border-[var(--color-border)] rounded-3xl p-6 md:p-8 shadow-xl animate-pulse min-h-[650px]">
            <!-- Left Panel -->
            <div class="lg:col-span-5 space-y-6">
              <div>
                <div class="h-8 bg-[var(--color-border)] rounded-md w-3/4 mb-2"></div>
                <div class="h-4 bg-[var(--color-border)]/60 rounded-md w-1/2"></div>
              </div>
              <div class="space-y-2">
                <div class="h-4 bg-[var(--color-border)] rounded-md w-1/3"></div>
                <div class="h-12 bg-[var(--bg-primary)] border border-[var(--color-border)] rounded-xl"></div>
              </div>
              <div class="space-y-3">
                <div class="flex justify-between">
                  <div class="h-4 bg-[var(--color-border)] rounded-md w-1/2"></div>
                  <div class="h-5 bg-[var(--color-border)] rounded-md w-12"></div>
                </div>
                <div class="h-2 bg-[var(--color-border)] rounded-lg w-full"></div>
              </div>
              <div class="space-y-3">
                <div class="flex justify-between">
                  <div class="h-4 bg-[var(--color-border)] rounded-md w-1/3"></div>
                  <div class="h-5 bg-[var(--color-border)] rounded-md w-16"></div>
                </div>
                <div class="h-2 bg-[var(--color-border)] rounded-lg w-full"></div>
              </div>
              <div class="h-16 bg-[var(--bg-primary)] border border-[var(--color-border)] rounded-2xl"></div>
              <div class="h-24 bg-[var(--bg-primary)]/50 border border-[var(--color-border)] rounded-2xl"></div>
            </div>
            <!-- Right Panel -->
            <div class="lg:col-span-7 flex flex-col justify-between space-y-6">
              <div>
                <div class="h-8 bg-[var(--color-border)] rounded-md w-1/2 mb-2"></div>
                <div class="h-4 bg-[var(--color-border)]/60 rounded-md w-2/3"></div>
              </div>
              <div class="h-40 bg-[var(--bg-primary)] border border-[var(--color-border)] rounded-3xl"></div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="h-24 bg-[var(--bg-primary)] border border-[var(--color-border)] rounded-2xl"></div>
                <div class="h-24 bg-[var(--bg-primary)] border border-[var(--color-border)] rounded-2xl"></div>
                <div class="h-24 bg-[var(--bg-primary)] border border-[var(--color-border)] rounded-2xl"></div>
                <div class="h-24 bg-[var(--bg-primary)] border border-[var(--color-border)] rounded-2xl"></div>
              </div>
              <div class="h-12 bg-[var(--bg-primary)] border border-[var(--color-border)] rounded-2xl"></div>
            </div>
          </div>
        </RebateCalculator>
      </div>
    </div>

    <!-- SME Decarbonization Hub Panel -->
    <div id="panel-sme" class="hidden space-y-8 animate-fade-in">
      <SmeHub 
        client:visible 
        defaultGridRate={localSpecs.gridRate}
        defaultSunHours={localSpecs.sunHours}
        defaultGridEmissions={localSpecs.gridEmissions}
        defaultCostPerWatt={localSpecs.costPerWatt}
        state={displayState}
        city={displayCity}
        lang={lang}
        regionEntry={match}
      />
    </div>
  </main>

  <script>
    // Robust event delegation on document ensures click handlers survive Astro ClientRouter transitions and DOM morphs
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      const btn = target?.closest('#btn-residential, #btn-sme');
      if (!btn) return;

      const btnRes = document.getElementById('btn-residential');
      const btnSme = document.getElementById('btn-sme');
      const panelRes = document.getElementById('panel-residential');
      const panelSme = document.getElementById('panel-sme');

      if (!btnRes || !btnSme || !panelRes || !panelSme) return;

      if (btn.id === 'btn-residential') {
        // Toggle Buttons
        btnRes.classList.add('border-[var(--color-accent)]', 'text-[var(--text-main)]', 'font-bold');
        btnRes.classList.remove('text-[var(--text-muted)]', 'font-medium', 'border-transparent');
        btnSme.classList.add('text-[var(--text-muted)]', 'font-medium', 'border-transparent');
        btnSme.classList.remove('border-[var(--color-accent)]', 'text-[var(--text-main)]', 'font-bold');

        // Toggle Panels
        panelRes.classList.remove('hidden');
        panelRes.classList.add('animate-fade-in');
        panelSme.classList.add('hidden');
        panelSme.classList.remove('animate-fade-in');
      } else {
        // Toggle Buttons
        btnSme.classList.add('border-[var(--color-accent)]', 'text-[var(--text-main)]', 'font-bold');
        btnSme.classList.remove('text-[var(--text-muted)]', 'font-medium', 'border-transparent');
        btnRes.classList.add('text-[var(--text-muted)]', 'font-medium', 'border-transparent');
        btnRes.classList.remove('border-[var(--color-accent)]', 'text-[var(--text-main)]', 'font-bold');

        // Toggle Panels
        panelSme.classList.remove('hidden');
        panelSme.classList.add('animate-fade-in');
        panelRes.classList.add('hidden');
        panelRes.classList.remove('animate-fade-in');
      }
    });
  </script>
</body>
</html>
