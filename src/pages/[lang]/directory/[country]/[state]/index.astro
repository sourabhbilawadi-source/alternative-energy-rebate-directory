---
import '../../../../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { supabase } from '../../../../../lib/supabase';
import { useTranslations } from '../../../../../lib/i18n';
import Analytics from '../../../../../components/Analytics.astro';

export async function getStaticPaths() {
  const langs = ['en-us', 'de-de', 'fr-fr'];
  let regions = [
    { country: 'us', state: 'california' },
    { country: 'us', state: 'texas' },
    { country: 'us', state: 'new-york' },
    { country: 'uk', state: 'england' },
    { country: 'de', state: 'berlin' },
    { country: 'au', state: 'new-south-wales' },
    { country: 'ca', state: 'ontario' },
    { country: 'us', state: 'illinois' },
    { country: 'us', state: 'arizona' },
    { country: 'us', state: 'florida' },
    { country: 'us', state: 'washington' },
    { country: 'us', state: 'massachusetts' },
    { country: 'us', state: 'colorado' },
    { country: 'uk', state: 'scotland' },
    { country: 'de', state: 'bavaria' },
    { country: 'ca', state: 'british-columbia' },
    { country: 'au', state: 'victoria' }
  ];

  if (supabase) {
    try {
      const { data } = await supabase
        .from('regions')
        .select('country_code, state_province');
      
      if (data && data.length > 0) {
        const seen = new Set();
        const list = [];
        for (const r of data) {
          const country = r.country_code === 'gb' ? 'uk' : r.country_code.toLowerCase();
          const state = r.state_province.toLowerCase().replace(/\s+/g, '-');
          const key = `${country}:${state}`;
          if (!seen.has(key)) {
            seen.add(key);
            list.push({ country, state });
          }
        }
        regions = list;
      }
    } catch (err) {
      console.error('Failed to query regions for static paths in state index. Using fallbacks:', err);
    }
  }

  const paths = [];
  for (const lang of langs) {
    for (const r of regions) {
      paths.push({ params: { lang, country: r.country, state: r.state } });
    }
  }
  return paths;
}

const { lang, country, state } = Astro.params;
const t = useTranslations(lang || 'en-us');

const displayCountry = country?.toUpperCase() || '';
const displayState = state ? state.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ') : '';

// Fallback presets if Supabase not configured
const getCitiesPreset = (s: string) => {
  const sLower = s.toLowerCase();
  if (sLower === 'california') {
    return [
      { slug: 'los-angeles', name: 'Los Angeles' },
      { slug: 'san-francisco', name: 'San Francisco' }
    ];
  } else if (sLower === 'texas') {
    return [{ slug: 'houston', name: 'Houston' }];
  } else if (sLower === 'new-york') {
    return [{ slug: 'new-york-city', name: 'New York City' }];
  } else if (sLower === 'england') {
    return [{ slug: 'london', name: 'London' }];
  } else if (sLower === 'berlin') {
    return [{ slug: 'berlin', name: 'Berlin' }];
  } else if (sLower === 'new-south-wales') {
    return [{ slug: 'sydney', name: 'Sydney' }];
  } else if (sLower === 'ontario') {
    return [{ slug: 'toronto', name: 'Toronto' }];
  } else if (sLower === 'illinois') {
    return [{ slug: 'chicago', name: 'Chicago' }];
  } else if (sLower === 'arizona') {
    return [{ slug: 'phoenix', name: 'Phoenix' }];
  } else if (sLower === 'florida') {
    return [{ slug: 'miami', name: 'Miami' }];
  } else if (sLower === 'washington') {
    return [{ slug: 'seattle', name: 'Seattle' }];
  } else if (sLower === 'massachusetts') {
    return [{ slug: 'boston', name: 'Boston' }];
  } else if (sLower === 'colorado') {
    return [{ slug: 'denver', name: 'Denver' }];
  } else if (sLower === 'scotland') {
    return [{ slug: 'edinburgh', name: 'Edinburgh' }];
  } else if (sLower === 'bavaria') {
    return [{ slug: 'munich', name: 'Munich' }];
  } else if (sLower === 'british-columbia') {
    return [{ slug: 'vancouver', name: 'Vancouver' }];
  } else if (sLower === 'victoria') {
    return [{ slug: 'melbourne', name: 'Melbourne' }];
  }
  return [];
};

let citiesList = getCitiesPreset(state || '');

if (supabase) {
  try {
    const { data } = await supabase
      .from('regions')
      .select('city')
      .eq('country_code', country === 'uk' ? 'gb' : (country || 'us').toLowerCase())
      .ilike('state_province', (state || '').replace(/-/g, ' '));
    
    if (data && data.length > 0) {
      const uniqueCities = [...new Set(data.map(r => r.city))];
      citiesList = uniqueCities.map(name => {
        const slug = name.toLowerCase().replace(/\s+/g, '-');
        return { slug, name };
      });
    }
  } catch (err) {
    console.error('Failed to query cities from Supabase regions. Using presets:', err);
  }
}
---

<!DOCTYPE html>
<html lang={lang} data-theme="sage-minimalist">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/logo.png" />
  <title>Alternative Energy Rebate Directory | {displayState} Cities</title>
  <meta name="description" content={`Browse alternative energy rebate directories in ${displayState}, ${displayCountry} to compute solar ROI.`} />
  <ClientRouter />
  <script is:inline>
    // 1. Immediately apply saved theme to avoid flashing
    const savedTheme = localStorage.getItem('theme') || 'sage-minimalist';
    document.documentElement.setAttribute('data-theme', savedTheme);

    // 2. Re-bind event handlers on Astro page loads (ClientRouter compatibility)
    document.addEventListener('astro:page-load', () => {
      const activeTheme = localStorage.getItem('theme') || 'sage-minimalist';
      document.documentElement.setAttribute('data-theme', activeTheme);

      const themeSelect = document.getElementById('theme-select');
      if (themeSelect) {
        themeSelect.value = activeTheme;
        themeSelect.addEventListener('change', (e) => {
          const theme = e.target.value;
          localStorage.setItem('theme', theme);
          document.documentElement.setAttribute('data-theme', theme);
        });
      }

      const langSelect = document.getElementById('lang-select');
      if (langSelect) {
        langSelect.addEventListener('change', (e) => {
          const targetLang = e.target.value;
          const pathParts = window.location.pathname.split('/').filter(Boolean);
          
          if (pathParts.length === 0) {
            window.location.href = `/${targetLang}/directory`;
          } else {
            const supportedLangs = ['en-us', 'de-de', 'fr-fr'];
            if (supportedLangs.includes(pathParts[0])) {
              pathParts[0] = targetLang;
            } else {
              pathParts.unshift(targetLang);
            }
            window.location.href = `/${pathParts.join('/')}${window.location.search}`;
          }
        });
      }
    });
  </script>
  <Analytics />
</head>
<body class="min-h-screen flex flex-col justify-between">
  <!-- Navbar -->
  <header class="border-b border-[var(--color-border)] bg-[var(--bg-primary)]/80 backdrop-blur-md sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-bold text-lg tracking-tight text-[var(--text-main)] hover:opacity-80 transition-opacity group">
        <img src="/logo.png" alt="EcoRebates Logo" class="w-9 h-9 object-contain rounded-lg transition-transform duration-300 group-hover:scale-105" />
        <span>EcoRebates</span>
      </a>
      <nav class="hidden md:flex items-center gap-6 text-sm font-semibold text-[var(--text-muted)]">
        <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.directory}</a>
        <a href={`/${lang}/search`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.search}</a>
        <a href={`/${lang}/compare`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.compare}</a>
        <a href={`/${lang}/compliance`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.compliance}</a>
      </nav>
      <div class="flex items-center gap-3">
        <!-- Lang Selector -->
        <select 
          id="lang-select" 
          class="bg-[var(--bg-primary)] border border-[var(--color-border)] text-[var(--text-main)] text-sm rounded-xl px-2.5 py-1.5 outline-none font-semibold cursor-pointer transition-all hover:border-[var(--color-accent)]"
        >
          <option value="en-us" selected={lang === 'en-us'} class="bg-[var(--bg-primary)] text-[var(--text-main)]">EN-US</option>
          <option value="de-de" selected={lang === 'de-de'} class="bg-[var(--bg-primary)] text-[var(--text-main)]">DE-DE</option>
          <option value="fr-fr" selected={lang === 'fr-fr'} class="bg-[var(--bg-primary)] text-[var(--text-main)]">FR-FR</option>
        </select>

        <!-- Theme Selector -->
        <select 
          id="theme-select"
          class="bg-[var(--bg-primary)] border border-[var(--color-border)] text-[var(--text-main)] text-sm rounded-xl px-2.5 py-1.5 outline-none font-semibold cursor-pointer transition-all hover:border-[var(--color-accent)]"
        >
          <option value="sage-minimalist" class="bg-[var(--bg-primary)] text-[var(--text-main)]">Sage Minimalist</option>
          <option value="dark-forest" class="bg-[var(--bg-primary)] text-[var(--text-main)]">Dark Forest Luxury</option>
          <option value="mint-tech" class="bg-[var(--bg-primary)] text-[var(--text-main)]">Mint & Clean Tech</option>
        </select>

        <a href={`/${lang}/search`} class="bg-[var(--color-accent)] text-white font-bold text-sm px-4 py-2 rounded-xl">
          {t.nav.searchPortal}
        </a>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16 flex-grow">
    <!-- Breadcrumbs -->
    <nav class="text-sm text-[var(--text-muted)] mb-6 flex items-center gap-2" aria-label="Breadcrumb">
      <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)] capitalize">{t.nav.directory}</a>
      <span>/</span>
      <a href={`/${lang}/directory/${country}`} class="hover:text-[var(--text-main)] uppercase">{country}</a>
      <span>/</span>
      <span class="text-[var(--text-main)] font-semibold capitalize">{displayState}</span>
    </nav>

    <div class="text-center md:text-left mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight mb-3 text-[var(--text-main)]">{displayState} {t.directory.citiesTitle}</h1>
      <p class="text-lg text-[var(--text-muted)]">
        {lang === 'de-de' ? 'Wählen Sie Ihre Stadt aus, um auf den Sizing-Rechner, die Stromtarife und die aktiven Rabattverzeichnisse zuzugreifen.' : lang === 'fr-fr' ? "Sélectionnez votre ville pour accéder au simulateur de dimensionnement, aux tarifs d'électricité et aux répertoires de rabais actifs." : 'Select your city to access the sizing calculator, utility rates, and active rebate directories.'}
      </p>
    </div>

    <!-- City List -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {citiesList.map((cityItem) => (
        <a 
          href={`/${lang}/directory/${country}/${state}/${cityItem.slug}`}
          class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] rounded-xl p-5 flex justify-between items-center shadow-sm hover:shadow-md transition-all hover:scale-101 group animate-fade-in"
        >
          <span class="text-lg font-bold text-[var(--text-main)] group-hover:text-[var(--color-accent)] transition-colors">{cityItem.name}</span>
          <span class="text-sm text-[var(--color-accent)] font-semibold flex items-center gap-1">
            {t.common.calculate} &rarr;
          </span>
        </a>
      ))}
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-border)] bg-[var(--bg-primary)] py-8 text-center text-xs text-[var(--text-muted)]">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>{t.footer.copyright}</div>
      <div class="flex gap-4 flex-wrap justify-center">
        <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)]">{t.footer.directory}</a>
        <a href={`/${lang}/search`} class="hover:text-[var(--text-main)]">{t.footer.search}</a>
        <a href={`/${lang}/compare`} class="hover:text-[var(--text-main)]">{t.footer.compare}</a>
        <a href={`/${lang}/compliance`} class="hover:text-[var(--text-main)]">{t.footer.compliance}</a>
        <a href={`/${lang}/privacy`} class="hover:text-[var(--text-main)]">{t.footer.privacy}</a>
        <a href={`/${lang}/terms`} class="hover:text-[var(--text-main)]">{t.footer.terms}</a>
      </div>
    </div>
  </footer>
</body>
</html>
