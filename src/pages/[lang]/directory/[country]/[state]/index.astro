---
import '../../../../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { supabase } from '../../../../../lib/supabase';
import { useTranslations } from '../../../../../lib/i18n';
import Analytics from '../../../../../components/Analytics.astro';
import { regionsData } from '../../../../../data/regions';

export async function getStaticPaths() {
  const langs = ['en-us', 'de-de', 'fr-fr'];
  
  const seen = new Set();
  const list = [];
  for (const r of regionsData) {
    const key = `${r.countryCode}:${r.stateSlug}`;
    if (!seen.has(key)) {
      seen.add(key);
      list.push({ country: r.countryCode, state: r.stateSlug });
    }
  }
  let regions = list;

  if (supabase) {
    try {
      const { data, error } = await supabase
        .from('regions')
        .select('country_code, state_province, state_slug');
      
      if (error) {
        console.error("DEBUG: Supabase query error in state index getStaticPaths:", error);
      }
      
      if (data && data.length > 0) {
        const seenKeys = new Set(regions.map(r => `${r.country}:${r.state}`));
        for (const r of data) {
          const country = r.country_code === 'gb' ? 'uk' : r.country_code.toLowerCase();
          const state = r.state_slug || r.state_province.toLowerCase().replace(/\s+/g, '-');
          const key = `${country}:${state}`;
          if (!seenKeys.has(key)) {
            seenKeys.add(key);
            regions.push({ country, state });
          }
        }
      }
    } catch (err) {
      console.error('Failed to query regions for static paths in state index. Using fallbacks:', err);
    }
  }

  const paths = [];
  for (const lang of langs) {
    for (const r of regions) {
      paths.push({ params: { lang, country: r.country, state: r.state } });
    }
  }
  return paths;
}

const { lang, country, state } = Astro.params;
const t = useTranslations(lang || 'en-us');

const match = regionsData.find(r => r.countryCode === country && r.stateSlug === state);
const displayCountry = match?.countryName || country?.toUpperCase() || '';
const displayState = match?.stateName || (state ? state.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ') : '');

// Resolve cities from central data file
const getCitiesPreset = (s: string) => {
  const sLower = s.toLowerCase();
  return regionsData
    .filter(r => r.countryCode === country && r.stateSlug === sLower)
    .map(r => ({ slug: r.citySlug, name: r.cityName }));
};

let citiesList = getCitiesPreset(state || '');

if (supabase) {
  try {
    const { data } = await supabase
      .from('regions')
      .select('city')
      .eq('country_code', country === 'uk' ? 'gb' : (country || 'us').toLowerCase())
      .eq('state_slug', state);
    
    if (data && data.length > 0) {
      const uniqueCities = [...new Set(data.map(r => r.city))];
      citiesList = uniqueCities.map(name => {
        const slug = name.toLowerCase().replace(/\s+/g, '-');
        return { slug, name };
      });
    }
  } catch (err) {
    console.error('Failed to query cities from Supabase regions. Using presets:', err);
  }
}

let activeProgramsCount = 0;
if (supabase) {
  try {
    const { count } = await supabase
      .from('rebates')
      .select('*, regions!inner(*)', { count: 'exact', head: true })
      .eq('is_active', true)
      .eq('regions.country_code', country === 'uk' ? 'gb' : country.toLowerCase())
      .eq('regions.state_slug', state);
    if (count !== null) activeProgramsCount = count;
  } catch (err) {
    console.error('Failed to count active rebates for state:', err);
  }
}

const siteUrl = 'https://incentivemapper.com';
const canonicalUrl = `${siteUrl}/${lang}/directory/${country}/${state}`;
const alternates = ['en-us', 'de-de', 'fr-fr'].map(l => ({
  hreflang: l,
  url: `${siteUrl}/${l}/directory/${country}/${state}`
}));

// Localized SEO titles & descriptions
const seoTitle = `${displayState}, ${displayCountry} ${lang === 'de-de' ? 'Energieförderungen' : lang === 'fr-fr' ? 'Subventions d\'énergie' : 'Energy Rebates'} — 2026`;

const seoDescription = lang === 'de-de'
  ? `Finden Sie ${activeProgramsCount} aktive Energieförderungen, Solar- und Batterierabatte in ${displayState}, ${displayCountry}. Berechnen Sie Sizing und ROI.`
  : lang === 'fr-fr'
    ? `Trouvez ${activeProgramsCount} subventions d'énergie actives, aides solaires et batteries à ${displayState}, ${displayCountry}. Calculez votre ROI.`
    : `Find ${activeProgramsCount} active energy rebates, solar incentives, and battery grants in ${displayState}, ${displayCountry}. Calculate your green sizing ROI.`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": lang === 'de-de' ? 'Startseite' : lang === 'fr-fr' ? 'Accueil' : 'Home',
      "item": `${siteUrl}/${lang}`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": displayCountry,
      "item": `${siteUrl}/${lang}/directory/${country}`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": displayState,
      "item": canonicalUrl
    }
  ]
};

import Navbar from '../../../../../components/Navbar.astro';
import ThemeFonts from '../../../../../components/ThemeFonts.astro';
---

<!DOCTYPE html>
<html lang={lang} data-theme="sage-minimalist">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <title>{seoTitle}</title>
  <meta name="description" content={seoDescription} />

  <!-- Canonical & hreflang Alternate Declarations -->
  <link rel="canonical" href={canonicalUrl} />
  {alternates.map(alt => (
    <link rel="alternate" hreflang={alt.hreflang} href={alt.url} />
  ))}

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <ClientRouter />
  <script is:inline>
    // 1. Immediately apply saved theme to avoid flashing
    const savedTheme = localStorage.getItem('theme') || 'sage-minimalist';
    document.documentElement.setAttribute('data-theme', savedTheme);

    // 2. Re-bind theme on Astro page loads (ClientRouter compatibility)
    document.addEventListener('astro:page-load', () => {
      const activeTheme = localStorage.getItem('theme') || 'sage-minimalist';
      document.documentElement.setAttribute('data-theme', activeTheme);
    });
  </script>
  
  <ThemeFonts />
  <Analytics />
</head>
<body class="min-h-screen flex flex-col justify-between">
  <Navbar lang={lang} />

  <!-- Main Content -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16 flex-grow">
    <!-- Breadcrumbs -->
    <nav class="text-sm text-[var(--text-muted)] mb-6 flex items-center gap-2 flex-wrap" aria-label="Breadcrumb">
      <a href={`/${lang}`} class="hover:text-[var(--text-main)] transition-colors">{lang === 'de-de' ? 'Startseite' : lang === 'fr-fr' ? 'Accueil' : 'Home'}</a>
      <span>/</span>
      <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)] transition-colors capitalize">{t.nav.directory}</a>
      <span>/</span>
      <a href={`/${lang}/directory/${country}`} class="hover:text-[var(--text-main)] transition-colors uppercase">{country}</a>
      <span>/</span>
      <span class="text-[var(--text-main)] font-semibold capitalize" aria-current="page">{displayState}</span>
    </nav>

    <div class="text-center md:text-left mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight mb-3 text-[var(--text-main)]">{displayState} {t.directory.citiesTitle}</h1>
      <p class="text-lg text-[var(--text-muted)]">
        {lang === 'de-de' ? 'Wählen Sie Ihre Stadt aus, um auf den Sizing-Rechner, die Stromtarife und die aktiven Rabattverzeichnisse zuzugreifen.' : lang === 'fr-fr' ? "Sélectionnez votre ville pour accéder au simulateur de dimensionnement, aux tarifs d'électricité et aux répertoires de rabais actifs." : 'Select your city to access the sizing calculator, utility rates, and active rebate directories.'}
      </p>
    </div>

    <!-- City List -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {citiesList.map((cityItem) => (
        <a 
          href={`/${lang}/directory/${country}/${state}/${cityItem.slug}`}
          class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] rounded-xl p-5 flex justify-between items-center shadow-sm hover:shadow-md transition-all hover:scale-101 group animate-fade-in"
        >
          <span class="text-lg font-bold text-[var(--text-main)] group-hover:text-[var(--color-accent)] transition-colors">{cityItem.name}</span>
          <span class="text-sm text-[var(--color-accent)] font-semibold flex items-center gap-1">
            {t.common.calculate} &rarr;
          </span>
        </a>
      ))}
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-border)] bg-[var(--bg-primary)] py-8 text-center text-xs text-[var(--text-muted)]">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>{t.footer.copyright}</div>
      <div class="flex gap-4 flex-wrap justify-center">
        <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)]">{t.footer.directory}</a>
        <a href={`/${lang}/search`} class="hover:text-[var(--text-main)]">{t.footer.search}</a>
        <a href={`/${lang}/compare`} class="hover:text-[var(--text-main)]">{t.footer.compare}</a>
        <a href={`/${lang}/compliance`} class="hover:text-[var(--text-main)]">{t.footer.compliance}</a>
        <a href={`/${lang}/blog`} class="hover:text-[var(--text-main)]">{t.footer.blog}</a>
        <a href={`/${lang}/privacy`} class="hover:text-[var(--text-main)]">{t.footer.privacy}</a>
        <a href={`/${lang}/terms`} class="hover:text-[var(--text-main)]">{t.footer.terms}</a>
      </div>
    </div>
  </footer>
</body>
</html>
