---
import '../../../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { supabase } from '../../../../lib/supabase';
import { useTranslations } from '../../../../lib/i18n';
import Analytics from '../../../../components/Analytics.astro';
import { regionsData, COUNTRY_METADATA } from '../../../../data/regions';

export async function getStaticPaths() {
  const langs = ['en-us', 'de-de', 'fr-fr'];
  let countries = [...new Set(regionsData.map(r => r.countryCode))];

  if (supabase) {
    try {
      const { data } = await supabase
        .from('regions')
        .select('country_code');
      
      if (data && data.length > 0) {
        const dbCodes = data.map(r => r.country_code.toLowerCase() === 'gb' ? 'uk' : r.country_code.toLowerCase());
        countries = [...new Set([...countries, ...dbCodes])];
      }
    } catch (err) {
      console.error('Failed to query countries for static paths in country index. Using fallbacks:', err);
    }
  }

  const paths = [];
  for (const lang of langs) {
    for (const country of countries) {
      paths.push({ params: { lang, country } });
    }
  }
  return paths;
}

const { lang, country } = Astro.params;
const t = useTranslations(lang || 'en-us');

const displayCountry = (country && COUNTRY_METADATA[country.toLowerCase()]) 
  ? COUNTRY_METADATA[country.toLowerCase()].name 
  : (country === 'uk' ? 'United Kingdom' : country === 'us' ? 'United States' : country === 'de' ? 'Germany' : country === 'ca' ? 'Canada' : country === 'au' ? 'Australia' : (country || '').toUpperCase());

// Resolve unique states and their city count dynamically
const getStatesPreset = (c: string) => {
  const code = c.toLowerCase();
  const countryRegions = regionsData.filter(r => r.countryCode === code);
  
  const stateMap = new Map<string, { name: string; citiesCount: number }>();
  for (const r of countryRegions) {
    const existing = stateMap.get(r.stateSlug);
    if (existing) {
      existing.citiesCount += 1;
    } else {
      stateMap.set(r.stateSlug, { name: r.stateName, citiesCount: 1 });
    }
  }
  
  return Array.from(stateMap.entries()).map(([slug, info]) => ({
    slug,
    name: info.name,
    citiesCount: info.citiesCount
  }));
};

let statesList = getStatesPreset(country || '');

if (supabase) {
  try {
    const { data } = await supabase
      .from('regions')
      .select('state_province')
      .eq('country_code', country === 'uk' ? 'gb' : (country || 'us').toLowerCase());
    
    if (data && data.length > 0) {
      const uniqueStates = [...new Set(data.map(r => r.state_province))];
      statesList = uniqueStates.map(name => {
        const slug = name.toLowerCase().replace(/\s+/g, '-');
        const count = data.filter(r => r.state_province === name).length;
        return { slug, name, citiesCount: count };
      });
    }
  } catch (err) {
    console.error('Failed to query states from Supabase regions. Using presets:', err);
  }
}

let activeProgramsCount = 0;
if (supabase) {
  try {
    const { count } = await supabase
      .from('rebates')
      .select('*, regions!inner(*)', { count: 'exact', head: true })
      .eq('is_active', true)
      .eq('regions.country_code', country === 'uk' ? 'gb' : country.toLowerCase());
    if (count !== null) activeProgramsCount = count;
  } catch (err) {
    console.error('Failed to count active rebates for country:', err);
  }
}

const siteUrl = 'https://incentivemapper.com';
const canonicalUrl = `${siteUrl}/${lang}/directory/${country}`;
const alternates = ['en-us', 'de-de', 'fr-fr'].map(l => ({
  hreflang: l,
  url: `${siteUrl}/${l}/directory/${country}`
}));

// Localized SEO titles & descriptions
const seoTitle = `${lang === 'de-de' ? 'Energieförderungen in' : lang === 'fr-fr' ? 'Subventions d\'énergie en' : 'Energy Rebates in'} ${displayCountry} — 2026 ${lang === 'de-de' ? 'Programme' : lang === 'fr-fr' ? 'Programmes' : 'Programs'}`;

const seoDescription = lang === 'de-de'
  ? `Vergleichen Sie ${activeProgramsCount} aktive Energieförderungen, Solarzuschüsse und Steuergutschriften in ${displayCountry} in ${statesList.length} Regionen.`
  : lang === 'fr-fr'
    ? `Comparez ${activeProgramsCount} subventions vertes actives en ${displayCountry} dans ${statesList.length} départements/régions.`
    : `Compare ${activeProgramsCount} active green energy rebates, solar grants, and tax credits in ${displayCountry} across ${statesList.length} states/regions.`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": lang === 'de-de' ? 'Startseite' : lang === 'fr-fr' ? 'Accueil' : 'Home',
      "item": `${siteUrl}/${lang}`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": t.nav.directory,
      "item": `${siteUrl}/${lang}/directory`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": displayCountry,
      "item": canonicalUrl
    }
  ]
};

import Navbar from '../../../../components/Navbar.astro';
---

<!DOCTYPE html>
<html lang={lang} data-theme="sage-minimalist">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <title>{seoTitle}</title>
  <meta name="description" content={seoDescription} />

  <!-- Canonical & hreflang Alternate Declarations -->
  <link rel="canonical" href={canonicalUrl} />
  {alternates.map(alt => (
    <link rel="alternate" hreflang={alt.hreflang} href={alt.url} />
  ))}

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <ClientRouter />
  <script is:inline>
    // 1. Immediately apply saved theme to avoid flashing
    const savedTheme = localStorage.getItem('theme') || 'sage-minimalist';
    document.documentElement.setAttribute('data-theme', savedTheme);

    // 2. Re-bind event handlers on Astro page loads (ClientRouter compatibility)
    document.addEventListener('astro:page-load', () => {
      const activeTheme = localStorage.getItem('theme') || 'sage-minimalist';
      document.documentElement.setAttribute('data-theme', activeTheme);

      const themeSelect = document.getElementById('theme-select');
      if (themeSelect) {
        themeSelect.value = activeTheme;
        themeSelect.addEventListener('change', (e) => {
          const theme = e.target.value;
          localStorage.setItem('theme', theme);
          document.documentElement.setAttribute('data-theme', theme);
        });
      }

      const langSelect = document.getElementById('lang-select');
      if (langSelect) {
        langSelect.addEventListener('change', (e) => {
          const targetLang = e.target.value;
          const pathParts = window.location.pathname.split('/').filter(Boolean);
          
          if (pathParts.length === 0) {
            window.location.href = `/${targetLang}/directory`;
          } else {
            const supportedLangs = ['en-us', 'de-de', 'fr-fr'];
            if (supportedLangs.includes(pathParts[0])) {
              pathParts[0] = targetLang;
            } else {
              pathParts.unshift(targetLang);
            }
            window.location.href = `/${pathParts.join('/')}${window.location.search}`;
          }
        });
      }
    });
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Open+Sans:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body class="min-h-screen flex flex-col justify-between">
  <Navbar lang={lang} />

  <!-- Main Content -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16 flex-grow">
    <!-- Breadcrumbs -->
    <nav class="text-sm text-[var(--text-muted)] mb-6 flex items-center gap-2 flex-wrap" aria-label="Breadcrumb">
      <a href={`/${lang}`} class="hover:text-[var(--text-main)] transition-colors">{lang === 'de-de' ? 'Startseite' : lang === 'fr-fr' ? 'Accueil' : 'Home'}</a>
      <span>/</span>
      <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)] transition-colors capitalize">{t.nav.directory}</a>
      <span>/</span>
      <span class="text-[var(--text-main)] font-semibold uppercase" aria-current="page">{country}</span>
    </nav>

    <div class="text-center md:text-left mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight mb-3 text-[var(--text-main)]">{displayCountry} {t.directory.statesTitle}</h1>
      <p class="text-lg text-[var(--text-muted)]">
        {lang === 'de-de' ? 'Wählen Sie Ihr Bundesland oder Ihre Provinz aus, um aktive alternative Energieförderungen, Rabatte und ROI-Tools anzuzeigen.' : lang === 'fr-fr' ? 'Sélectionnez votre État ou votre province pour voir les subventions actives, les rabais et les outils de calcul du ROI.' : 'Select your state or province to see active alternative energy incentives, rebates, and ROI tools.'}
      </p>
    </div>

    <!-- State List -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {statesList.map((stateItem) => (
        <a 
          href={`/${lang}/directory/${country}/${stateItem.slug}`}
          class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] rounded-xl p-5 flex justify-between items-center shadow-sm hover:shadow-md transition-all hover:scale-101 group"
        >
          <span class="text-lg font-bold text-[var(--text-main)] group-hover:text-[var(--color-accent)] transition-colors">{stateItem.name}</span>
          <span class="text-xs bg-[var(--bg-primary)] border border-[var(--color-border)] px-2.5 py-1 rounded-full text-[var(--text-muted)]">
            {stateItem.citiesCount} {t.directory.citiesTitle}
          </span>
        </a>
      ))}
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-border)] bg-[var(--bg-primary)] py-8 text-center text-xs text-[var(--text-muted)]">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>{t.footer.copyright}</div>
      <div class="flex gap-4 flex-wrap justify-center">
        <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)] font-semibold">{t.footer.directory}</a>
        <a href={`/${lang}/search`} class="hover:text-[var(--text-main)]">{t.footer.search}</a>
        <a href={`/${lang}/compare`} class="hover:text-[var(--text-main)]">{t.footer.compare}</a>
        <a href={`/${lang}/compliance`} class="hover:text-[var(--text-main)]">{t.footer.compliance}</a>
        <a href={`/${lang}/blog`} class="hover:text-[var(--text-main)]">{t.footer.blog}</a>
        <a href={`/${lang}/privacy`} class="hover:text-[var(--text-main)]">{t.footer.privacy}</a>
        <a href={`/${lang}/terms`} class="hover:text-[var(--text-main)]">{t.footer.terms}</a>
      </div>
    </div>
  </footer>
</body>
</html>
