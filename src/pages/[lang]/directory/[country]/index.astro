---
import '../../../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { supabase } from '../../../../lib/supabase';
import { useTranslations } from '../../../../lib/i18n';
import Analytics from '../../../../components/Analytics.astro';

export async function getStaticPaths() {
  const langs = ['en-us', 'de-de', 'fr-fr'];
  let countries = ['us', 'uk', 'de', 'ca', 'au'];

  if (supabase) {
    try {
      const { data } = await supabase
        .from('regions')
        .select('country_code');
      
      if (data && data.length > 0) {
        const uniqueCodes = [...new Set(data.map(r => r.country_code.toLowerCase()))];
        countries = uniqueCodes.map(code => code === 'gb' ? 'uk' : code);
      }
    } catch (err) {
      console.error('Failed to query countries for static paths in country index. Using fallbacks:', err);
    }
  }

  const paths = [];
  for (const lang of langs) {
    for (const country of countries) {
      paths.push({ params: { lang, country } });
    }
  }
  return paths;
}

const { lang, country } = Astro.params;
const t = useTranslations(lang || 'en-us');

const displayCountry = country === 'uk' ? 'United Kingdom' : country === 'us' ? 'United States' : country === 'de' ? 'Germany' : country === 'ca' ? 'Canada' : country === 'au' ? 'Australia' : (country || '').toUpperCase();

// Fallback presets if Supabase not configured
const getStatesPreset = (c: string) => {
  const code = c.toLowerCase();
  if (code === 'us') {
    return [
      { slug: 'california', name: 'California', citiesCount: 2 },
      { slug: 'texas', name: 'Texas', citiesCount: 1 },
      { slug: 'new-york', name: 'New York', citiesCount: 1 },
      { slug: 'illinois', name: 'Illinois', citiesCount: 1 },
      { slug: 'arizona', name: 'Arizona', citiesCount: 1 },
      { slug: 'florida', name: 'Florida', citiesCount: 1 },
      { slug: 'washington', name: 'Washington', citiesCount: 1 },
      { slug: 'massachusetts', name: 'Massachusetts', citiesCount: 1 },
      { slug: 'colorado', name: 'Colorado', citiesCount: 1 }
    ];
  } else if (code === 'uk') {
    return [
      { slug: 'england', name: 'England', citiesCount: 1 },
      { slug: 'scotland', name: 'Scotland', citiesCount: 1 }
    ];
  } else if (code === 'de') {
    return [
      { slug: 'berlin', name: 'Berlin', citiesCount: 1 },
      { slug: 'bavaria', name: 'Bavaria', citiesCount: 1 }
    ];
  } else if (code === 'au') {
    return [
      { slug: 'new-south-wales', name: 'New South Wales', citiesCount: 1 },
      { slug: 'victoria', name: 'Victoria', citiesCount: 1 }
    ];
  } else if (code === 'ca') {
    return [
      { slug: 'ontario', name: 'Ontario', citiesCount: 1 },
      { slug: 'british-columbia', name: 'British Columbia', citiesCount: 1 }
    ];
  }
  return [];
};

let statesList = getStatesPreset(country || '');

if (supabase) {
  try {
    const { data } = await supabase
      .from('regions')
      .select('state_province')
      .eq('country_code', country === 'uk' ? 'gb' : (country || 'us').toLowerCase());
    
    if (data && data.length > 0) {
      const uniqueStates = [...new Set(data.map(r => r.state_province))];
      statesList = uniqueStates.map(name => {
        const slug = name.toLowerCase().replace(/\s+/g, '-');
        const count = data.filter(r => r.state_province === name).length;
        return { slug, name, citiesCount: count };
      });
    }
  } catch (err) {
    console.error('Failed to query states from Supabase regions. Using presets:', err);
  }
}
---

<!DOCTYPE html>
<html lang={lang} data-theme="sage-minimalist">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/logo.png" />
  <title>Alternative Energy Rebate Directory | {displayCountry} States</title>
  <meta name="description" content={`Browse alternative energy rebate directories in ${displayCountry} to find regional incentives.`} />
  <ClientRouter />
  <Analytics />
</head>
<body class="min-h-screen flex flex-col justify-between">
  <!-- Navbar -->
  <header class="border-b border-[var(--color-border)] bg-[var(--bg-primary)]/80 backdrop-blur-md sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-bold text-lg tracking-tight text-[var(--text-main)] hover:opacity-80 transition-opacity group">
        <img src="/logo.png" alt="EcoRebates Logo" class="w-9 h-9 object-contain rounded-lg transition-transform duration-300 group-hover:scale-105" />
        <span>EcoRebates</span>
      </a>
      <nav class="hidden md:flex items-center gap-6 text-sm font-semibold text-[var(--text-muted)]">
        <a href={`/${lang}/directory`} class="text-[var(--text-main)] transition-colors">{t.nav.directory}</a>
        <a href={`/${lang}/search`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.search}</a>
        <a href={`/${lang}/compare`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.compare}</a>
        <a href={`/${lang}/compliance`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.compliance}</a>
      </nav>
      <a href={`/${lang}/search`} class="bg-[var(--color-accent)] text-white font-bold text-sm px-4 py-2 rounded-xl">
        {t.nav.searchPortal}
      </a>
    </div>
  </header>

  <!-- Main Content -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16 flex-grow">
    <!-- Breadcrumbs -->
    <nav class="text-sm text-[var(--text-muted)] mb-6 flex items-center gap-2" aria-label="Breadcrumb">
      <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)] capitalize">{t.nav.directory}</a>
      <span>/</span>
      <span class="text-[var(--text-main)] font-semibold uppercase">{country}</span>
    </nav>

    <div class="text-center md:text-left mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight mb-3 text-[var(--text-main)]">{displayCountry} {t.directory.statesTitle}</h1>
      <p class="text-lg text-[var(--text-muted)]">
        {lang === 'de-de' ? 'Wählen Sie Ihr Bundesland oder Ihre Provinz aus, um aktive alternative Energieförderungen, Rabatte und ROI-Tools anzuzeigen.' : lang === 'fr-fr' ? 'Sélectionnez votre État ou votre province pour voir les subventions actives, les rabais et les outils de calcul du ROI.' : 'Select your state or province to see active alternative energy incentives, rebates, and ROI tools.'}
      </p>
    </div>

    <!-- State List -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {statesList.map((stateItem) => (
        <a 
          href={`/${lang}/directory/${country}/${stateItem.slug}`}
          class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] rounded-xl p-5 flex justify-between items-center shadow-sm hover:shadow-md transition-all hover:scale-101 group"
        >
          <span class="text-lg font-bold text-[var(--text-main)] group-hover:text-[var(--color-accent)] transition-colors">{stateItem.name}</span>
          <span class="text-xs bg-[var(--bg-primary)] border border-[var(--color-border)] px-2.5 py-1 rounded-full text-[var(--text-muted)]">
            {stateItem.citiesCount} {t.directory.citiesTitle}
          </span>
        </a>
      ))}
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-border)] bg-[var(--bg-primary)] py-8 text-center text-xs text-[var(--text-muted)]">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>{t.footer.copyright}</div>
      <div class="flex gap-4 flex-wrap justify-center">
        <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)] font-semibold">{t.footer.directory}</a>
        <a href={`/${lang}/search`} class="hover:text-[var(--text-main)]">{t.footer.search}</a>
        <a href={`/${lang}/compare`} class="hover:text-[var(--text-main)]">{t.footer.compare}</a>
        <a href={`/${lang}/compliance`} class="hover:text-[var(--text-main)]">{t.footer.compliance}</a>
        <a href={`/${lang}/privacy`} class="hover:text-[var(--text-main)]">{t.footer.privacy}</a>
        <a href={`/${lang}/terms`} class="hover:text-[var(--text-main)]">{t.footer.terms}</a>
      </div>
    </div>
  </footer>
</body>
</html>
