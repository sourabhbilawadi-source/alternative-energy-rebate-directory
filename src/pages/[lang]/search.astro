---
import '../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import SearchPortal from '../../components/search/SearchPortal';
import { useTranslations } from '../../lib/i18n';

export async function getStaticPaths() {
  return [
    { params: { lang: 'en-us' } },
    { params: { lang: 'de-de' } },
    { params: { lang: 'fr-fr' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang || 'en-us');
---

<!DOCTYPE html>
<html lang={lang} data-theme="sage-minimalist">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/logo.png" />
  <title>{t.search.title} | EcoRebates</title>
  <meta name="description" content="Search federal, state, and local utility rebate programs, solar tax credits, and battery incentives dynamically." />

  <!-- Open Graph / Facebook Preview Metadata -->
  <meta property="og:title" content={`${t.search.title} | EcoRebates`} />
  <meta property="og:description" content="Search federal, state, and local utility rebate programs, solar tax credits, and battery incentives dynamically." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://ecorebates.org/${lang}/search`} />
  <meta property="og:image" content="https://ecorebates.org/og-preview.png" />

  <!-- Twitter Card Metadata -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${t.search.title} | EcoRebates`} />
  <meta name="twitter:description" content="Search federal, state, and local utility rebate programs, solar tax credits, and battery incentives dynamically." />
  <meta name="twitter:image" content="https://ecorebates.org/og-preview.png" />
  <ClientRouter />
</head>
<body class="min-h-screen flex flex-col justify-between">
  <!-- Navbar -->
  <header class="border-b border-[var(--color-border)] bg-[var(--bg-primary)]/80 backdrop-blur-md sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <img src="/logo.png" alt="EcoRebates Logo" class="w-8 h-8 object-contain rounded-lg" />
        <a href="/" class="font-bold text-lg tracking-tight text-[var(--text-main)]">EcoRebates</a>
      </div>
      <nav class="hidden md:flex items-center gap-6 text-sm font-semibold text-[var(--text-muted)]">
        <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.directory}</a>
        <a href={`/${lang}/search`} class="text-[var(--text-main)] transition-colors">{t.nav.search}</a>
        <a href={`/${lang}/compare`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.compare}</a>
        <a href={`/${lang}/compliance`} class="hover:text-[var(--text-main)] transition-colors">{t.nav.compliance}</a>
      </nav>
      <a href={`/${lang}/directory`} class="bg-[var(--color-accent)] text-white font-bold text-sm px-4 py-2 rounded-xl">
        {t.nav.browseDir}
      </a>
    </div>
  </header>

  <!-- Main Content -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16 flex-grow" transition:animate="slide">
    <div class="text-center md:text-left mb-8">
      <h1 class="text-4xl font-extrabold tracking-tight mb-3 text-[var(--text-main)]">{t.search.title}</h1>
      <p class="text-lg text-[var(--text-muted)]">{t.search.subtitle}</p>
    </div>

    <!-- Search Portal React Island -->
    <SearchPortal client:load lang={lang} />
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-border)] bg-[var(--bg-primary)] py-8 text-center text-xs text-[var(--text-muted)]">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>{t.footer.copyright}</div>
      <div class="flex gap-4">
        <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)]">{t.footer.directory}</a>
        <a href={`/${lang}/search`} class="hover:text-[var(--text-main)] font-semibold">{t.footer.search}</a>
        <a href={`/${lang}/compare`} class="hover:text-[var(--text-main)]">{t.footer.compare}</a>
        <a href={`/${lang}/compliance`} class="hover:text-[var(--text-main)]">{t.footer.compliance}</a>
        <a href={`/${lang}/admin`} class="hover:text-[var(--text-main)]">{t.footer.admin || 'Admin'}</a>
      </div>
    </div>
  </footer>
  
  <script>
    // Client-side initialization to grab query string 'q' and pass it to React
    const searchPortal = document.querySelector('input[type="text"]') as HTMLInputElement;
    if (searchPortal) {
      const urlParams = new URLSearchParams(window.location.search);
      const queryParam = urlParams.get('q');
      if (queryParam) {
        searchPortal.value = queryParam;
        // Trigger React onChange update
        const event = new Event('input', { bubbles: true });
        searchPortal.dispatchEvent(event);
      }
    }
  </script>
</body>
</html>
