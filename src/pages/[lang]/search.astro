---
import '../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import SearchPortal from '../../components/search/SearchPortal';
import { useTranslations } from '../../lib/i18n';
import Analytics from '../../components/Analytics.astro';

import { supabase } from '../../lib/supabase';

export async function getStaticPaths() {
  return [
    { params: { lang: 'en-us' } },
    { params: { lang: 'de-de' } },
    { params: { lang: 'fr-fr' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang || 'en-us');
import Navbar from '../../components/Navbar.astro';

// Fetch active rebates on the server side
let serverRebates = [];
if (supabase) {
  try {
    const { data } = await supabase
      .from('rebates')
      .select(`
        id,
        authority_name,
        technology_category,
        incentive_value,
        incentive_type,
        max_limit,
        regions (
          country_code,
          state_province,
          city,
          postal_code
        )
      `)
      .eq('is_active', true);
    
    if (data) {
      serverRebates = data.map((item: any) => ({
        id: item.id,
        authority_name: item.authority_name,
        technology_category: item.technology_category,
        incentive_value: Number(item.incentive_value),
        incentive_type: item.incentive_type,
        max_limit: item.max_limit ? Number(item.max_limit) : null,
        region: {
          country_code: item.regions?.country_code || 'us',
          state_province: item.regions?.state_province || '',
          city: item.regions?.city || '',
          postal_code: item.regions?.postal_code || ''
        }
      }));
    }
  } catch (err) {
    console.error('Failed to pre-fetch rebates from Supabase:', err);
  }
}

// Log build warning if no active records are returned
if (serverRebates.length === 0) {
  console.error("WARNING: Supabase rebates query returned 0 results, search page will be empty!");
}
---

<!DOCTYPE html>
<html lang={lang} data-theme="sage-minimalist">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <title>{t.search.title} | IncentiveMapper</title>
  <meta name="description" content="Search federal, state, and local utility rebate programs, solar tax credits, and battery incentives dynamically." />

  <!-- Open Graph / Facebook Preview Metadata -->
  <meta property="og:title" content={`${t.search.title} | IncentiveMapper`} />
  <meta property="og:description" content="Search federal, state, and local utility rebate programs, solar tax credits, and battery incentives dynamically." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://incentivemapper.com/${lang}/search`} />
  <meta property="og:image" content="https://incentivemapper.com/og-preview.png" />

  <!-- Twitter Card Metadata -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${t.search.title} | IncentiveMapper`} />
  <meta name="twitter:description" content="Search federal, state, and local utility rebate programs, solar tax credits, and battery incentives dynamically." />
  <meta name="twitter:image" content="https://incentivemapper.com/og-preview.png" />
  <ClientRouter />
  <script is:inline>
    // 1. Immediately apply saved theme to avoid flashing
    const savedTheme = localStorage.getItem('theme') || 'sage-minimalist';
    document.documentElement.setAttribute('data-theme', savedTheme);

    // 2. Re-bind event handlers on Astro page loads (ClientRouter compatibility)
    document.addEventListener('astro:page-load', () => {
      const activeTheme = localStorage.getItem('theme') || 'sage-minimalist';
      document.documentElement.setAttribute('data-theme', activeTheme);

      const themeSelect = document.getElementById('theme-select');
      if (themeSelect) {
        themeSelect.value = activeTheme;
        themeSelect.addEventListener('change', (e) => {
          const theme = e.target.value;
          localStorage.setItem('theme', theme);
          document.documentElement.setAttribute('data-theme', theme);
        });
      }

      const langSelect = document.getElementById('lang-select');
      if (langSelect) {
        langSelect.addEventListener('change', (e) => {
          const targetLang = e.target.value;
          const pathParts = window.location.pathname.split('/').filter(Boolean);
          
          if (pathParts.length === 0) {
            window.location.href = `/${targetLang}/directory`;
          } else {
            const supportedLangs = ['en-us', 'de-de', 'fr-fr'];
            if (supportedLangs.includes(pathParts[0])) {
              pathParts[0] = targetLang;
            } else {
              pathParts.unshift(targetLang);
            }
            window.location.href = `/${pathParts.join('/')}${window.location.search}`;
          }
        });
      }
    });
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Open+Sans:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body class="min-h-screen flex flex-col justify-between">
  <Navbar lang={lang} />

  <!-- Main Content -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16 flex-grow" transition:animate="slide">
    <div class="text-center md:text-left mb-8">
      <h1 class="text-4xl font-extrabold tracking-tight mb-3 text-[var(--text-main)]">{t.search.title}</h1>
      <p class="text-lg text-[var(--text-muted)]">{t.search.subtitle}</p>
    </div>

    <!-- Search Portal React Island -->
    <SearchPortal client:load lang={lang} initialRebates={serverRebates} />
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-border)] bg-[var(--bg-primary)] py-8 text-center text-xs text-[var(--text-muted)]">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>{t.footer.copyright}</div>
      <div class="flex gap-4 flex-wrap justify-center">
        <a href={`/${lang}/directory`} class="hover:text-[var(--text-main)]">{t.footer.directory}</a>
        <a href={`/${lang}/search`} class="hover:text-[var(--text-main)] font-semibold">{t.footer.search}</a>
        <a href={`/${lang}/compare`} class="hover:text-[var(--text-main)]">{t.footer.compare}</a>
        <a href={`/${lang}/compliance`} class="hover:text-[var(--text-main)]">{t.footer.compliance}</a>
        <a href={`/${lang}/blog`} class="hover:text-[var(--text-main)]">{t.footer.blog}</a>
        <a href={`/${lang}/privacy`} class="hover:text-[var(--text-main)]">{t.footer.privacy}</a>
        <a href={`/${lang}/terms`} class="hover:text-[var(--text-main)]">{t.footer.terms}</a>
      </div>
    </div>
  </footer>
</body>
</html>
