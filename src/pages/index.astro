---
import '../styles/global.css';
import Analytics from '../components/Analytics.astro';
import Navbar from '../components/Navbar.astro';
import ThemeFonts from '../components/ThemeFonts.astro';
import { supabase } from '../lib/supabase';

let categories: { name: string; slug: string; count: number }[] = [];

if (supabase) {
  try {
    const { data, error } = await supabase
      .from('rebates')
      .select('technology_category, authority_name, regions(country_code)')
      .eq('is_active', true);

    if (error) {
      console.warn('Failed to query active rebates for homepage categories:', error.message);
    } else if (data && data.length > 0) {
      const counts: Record<string, number> = {};
      const seenPrograms = new Set<string>();
      
      for (const r of data) {
        const cat = r.technology_category;
        const country = r.regions?.country_code?.toLowerCase() || 'us';
        const programKey = `${cat}:${country}:${r.authority_name}`;

        if (!seenPrograms.has(programKey)) {
          seenPrograms.add(programKey);
          counts[cat] = (counts[cat] || 0) + 1;
        }
      }

      const slugifyCategory = (category: string) => {
        return category
          .toLowerCase()
          .replace(/[^a-z0-9\s-]/g, '')
          .trim()
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-');
      };

      categories = Object.entries(counts)
        .map(([name, count]) => ({
          name,
          slug: slugifyCategory(name),
          count
        }))
        .sort((a, b) => b.count - a.count)
        .slice(0, 8);
    }
  } catch (err: any) {
    console.warn('Failed to fetch categories from Supabase at build time:', err?.message || err);
  }
} else {
  console.warn('Supabase client is not initialized at build time.');
}
---

<!DOCTYPE html>
<html lang="en" data-theme="sage-minimalist">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <title>IncentiveMapper | Alternative Energy Rebates Directory</title>
  <meta name="description" content="Calculate, compare, and map alternative energy rebates, federal tax credits, and government incentives across solar, EV, heat pump, and battery storage programs." />

  <!-- Canonical & hreflang Alternate Declarations -->
  <link rel="canonical" href="https://incentivemapper.com" />
  <link rel="alternate" hreflang="x-default" href="https://incentivemapper.com" />
  <link rel="alternate" hreflang="en-us" href="https://incentivemapper.com/en-us/directory" />
  <link rel="alternate" hreflang="de-de" href="https://incentivemapper.com/de-de/directory" />
  <link rel="alternate" hreflang="fr-fr" href="https://incentivemapper.com/fr-fr/directory" />

  <!-- Open Graph / Facebook Preview Metadata -->
  <meta property="og:title" content="IncentiveMapper | Alternative Energy Rebates Directory" />
  <meta property="og:description" content="Calculate, compare, and map alternative energy rebates, federal tax credits, and government incentives across solar, EV, heat pump, and battery storage programs." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://incentivemapper.com/" />
  <meta property="og:image" content="https://incentivemapper.com/og-preview.png" />
  
  <!-- Twitter Card Metadata -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="IncentiveMapper | Alternative Energy Rebates Directory" />
  <meta name="twitter:description" content="Calculate, compare, and map alternative energy rebates, federal tax credits, and government incentives across solar, EV, heat pump, and battery storage programs." />
  <meta name="twitter:image" content="https://incentivemapper.com/og-preview.png" />
  <script is:inline>
    // 1. Immediately apply saved theme to avoid flashing
    const savedTheme = localStorage.getItem('theme') || 'sage-minimalist';
    document.documentElement.setAttribute('data-theme', savedTheme);

    // 2. Re-bind theme on Astro page loads (ClientRouter compatibility)
    document.addEventListener('astro:page-load', () => {
      const activeTheme = localStorage.getItem('theme') || 'sage-minimalist';
      document.documentElement.setAttribute('data-theme', activeTheme);
    });
  </script>
  <ThemeFonts />
  <Analytics />
</head>
<body class="min-h-screen flex flex-col justify-between">
  
  <Navbar />

  <!-- Hero Section -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-20 text-center flex-grow flex flex-col justify-center">
    <div class="space-y-6">
      <div class="inline-flex items-center gap-2 bg-[var(--bg-secondary)] text-[var(--text-muted)] text-xs font-bold px-3.5 py-1.5 rounded-full border border-[var(--color-border)] shadow-sm transition-all duration-300 hover:scale-105">
        ✨ 124 DSIRE Policy Categories Supported
      </div>
      <h1 class="text-5xl md:text-6xl font-black tracking-tight text-[var(--text-main)] leading-tight animate-fade-in">
        Alternative Energy Sizing & Policy Directory
      </h1>
      <p class="text-lg md:text-xl text-[var(--text-muted)] max-w-2xl mx-auto">
        Compute localized payback timelines, solar capacity limits, and battery peak avoidance offsets. Discover regional utility grants and tax credits.
      </p>

      <!-- Dynamic Zip Search Box -->
      <div class="max-w-md mx-auto pt-4">
        <div class="bg-[var(--bg-secondary)] border border-[var(--color-border)] p-2 rounded-2xl flex items-center gap-2 shadow-md">
          <input 
            type="text" 
            id="home-zip"
            placeholder="Enter city, state, ZIP code..." 
            class="bg-[var(--bg-primary)] border border-[var(--color-border)] text-[var(--text-main)] rounded-xl py-3 px-4 outline-none flex-grow font-semibold"
            aria-label="Enter city, state, or ZIP code"
          />
          <button 
            id="home-search-btn"
            class="bg-[var(--color-accent)] hover:opacity-90 text-white font-bold px-6 py-3 rounded-xl transition-all"
          >
            Find Rebates
          </button>
        </div>
        <p id="search-feedback" class="text-xs text-red-500 mt-2 hidden"></p>
      </div>

      <!-- Quick Nav Links -->
      <div class="pt-8 space-y-3">
        <h3 class="text-sm font-bold text-[var(--text-muted)] uppercase tracking-wider">Featured Regional Portals</h3>
        <div class="flex flex-wrap justify-center gap-3">
          <a 
            href="/en-us/directory/us/california/los-angeles" 
            class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] px-4 py-2.5 rounded-xl text-sm font-bold transition-all hover:scale-105 inline-block text-[var(--text-main)] animate-fade-in"
          >
            Los Angeles, CA (High Utility Rates)
          </a>
          <a 
            href="/en-us/directory/us/texas/houston" 
            class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] px-4 py-2.5 rounded-xl text-sm font-bold transition-all hover:scale-105 inline-block text-[var(--text-main)] animate-fade-in"
          >
            Houston, TX (High Solar Yields)
          </a>
          <a 
            href="/en-us/directory/us/new-york/new-york-city" 
            class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] px-4 py-2.5 rounded-xl text-sm font-bold transition-all hover:scale-105 inline-block text-[var(--text-main)] animate-fade-in"
          >
            New York City, NY (ConEd & State Grants)
          </a>
          <a 
            href="/en-us/directory/us/illinois/chicago" 
            class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] px-4 py-2.5 rounded-xl text-sm font-bold transition-all hover:scale-105 inline-block text-[var(--text-main)] animate-fade-in"
          >
            Chicago, IL (ComEd Utility Rebates)
          </a>
          <a 
            href="/en-us/directory/au/new-south-wales/sydney" 
            class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] px-4 py-2.5 rounded-xl text-sm font-bold transition-all hover:scale-105 inline-block text-[var(--text-main)] animate-fade-in"
          >
            Sydney, NSW (Australian Solar Homes)
          </a>
          <a 
            href="/en-us/directory/ca/ontario/toronto" 
            class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] px-4 py-2.5 rounded-xl text-sm font-bold transition-all hover:scale-105 inline-block text-[var(--text-main)] animate-fade-in"
          >
            Toronto, ON (Greener Homes Program)
          </a>
          <a 
            href="/en-us/directory/uk/england/london" 
            class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] px-4 py-2.5 rounded-xl text-sm font-bold transition-all hover:scale-105 inline-block text-[var(--text-main)] animate-fade-in"
          >
            London, UK (European SGR Feed-in)
          </a>
        </div>
      </div>

      {categories.length > 0 && (
        <div class="pt-8 space-y-3">
          <h3 class="text-sm font-bold text-[var(--text-muted)] uppercase tracking-wider">Browse by Technology</h3>
          <div class="flex flex-wrap justify-center gap-3">
            {categories.map((cat) => (
              <a 
                href={`/en-us/category/${cat.slug}`}
                class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] px-4 py-2.5 rounded-xl text-sm font-bold transition-all hover:scale-105 inline-block text-[var(--text-main)] animate-fade-in"
              >
                {cat.name}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-border)] bg-[var(--bg-primary)] py-8 text-center text-xs text-[var(--text-muted)] mt-12">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>&copy; 2026 IncentiveMapper. All rights reserved.</div>
      <div class="flex flex-wrap justify-center gap-6">
        <a href="/en-us/directory" class="hover:text-[var(--text-main)]">Directory</a>
        <a href="/en-us/search" class="hover:text-[var(--text-main)]">Search</a>
        <a href="/en-us/compare" class="hover:text-[var(--text-main)]">Compare Sizing</a>
        <a href="/en-us/compliance" class="hover:text-[var(--text-main)]">DSIRE Compliance Guide</a>
        <a href="/en-us/privacy" class="hover:text-[var(--text-main)]">Privacy Policy</a>
        <a href="/en-us/terms" class="hover:text-[var(--text-main)]">Terms</a>
      </div>
    </div>
  </footer>

  <script>
    const searchBtn = document.getElementById('home-search-btn');
    const zipInput = document.getElementById('home-zip') as HTMLInputElement;
    const feedback = document.getElementById('search-feedback');

    if (searchBtn && zipInput && feedback) {
      searchBtn.addEventListener('click', () => {
        const query = zipInput.value.trim();
        if (!query) {
          feedback.textContent = 'Please enter a search term or ZIP code.';
          feedback.classList.remove('hidden');
          return;
        }

        feedback.classList.add('hidden');
        
        // If it's a 5-digit ZIP code, redirect using first-digit mapping
        if (/^\d{5}$/.test(query)) {
          const firstDigit = query.charAt(0);
          if (firstDigit === '9') {
            window.location.href = '/en-us/directory/us/california/los-angeles';
          } else if (firstDigit === '7') {
            window.location.href = '/en-us/directory/us/texas/houston';
          } else {
            // Default search fallback
            window.location.href = `/en-us/search?q=${encodeURIComponent(query)}`;
          }
        } else {
          // Otherwise redirect to search page
          window.location.href = `/en-us/search?q=${encodeURIComponent(query)}`;
        }
      });

      // Allow enter key press
      zipInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          searchBtn.click();
        }
      });
    }
  </script>
</body>
</html>
