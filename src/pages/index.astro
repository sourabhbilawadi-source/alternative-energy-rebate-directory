---
import '../styles/global.css';
import Analytics from '../components/Analytics.astro';
---

<!DOCTYPE html>
<html lang="en" data-theme="sage-minimalist">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/logo.png" />
  <title>IncentiveMapper | Alternative Energy Rebates Directory</title>
  <meta name="description" content="Discover alternative energy rebates, federal tax incentives, and solar sizing calculations for residential and enterprise clients globally." />
  
  <!-- Open Graph / Facebook Preview Metadata -->
  <meta property="og:title" content="IncentiveMapper | Alternative Energy Rebates Directory" />
  <meta property="og:description" content="Discover alternative energy rebates, federal tax incentives, and solar sizing calculations for residential and enterprise clients globally." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://incentivemapper.com/" />
  <meta property="og:image" content="https://incentivemapper.com/og-preview.png" />
  
  <!-- Twitter Card Metadata -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="IncentiveMapper | Alternative Energy Rebates Directory" />
  <meta name="twitter:description" content="Discover alternative energy rebates, federal tax incentives, and solar sizing calculations for residential and enterprise clients globally." />
  <meta name="twitter:image" content="https://incentivemapper.com/og-preview.png" />
  <script is:inline>
    // 1. Immediately apply saved theme to avoid flashing
    const savedTheme = localStorage.getItem('theme') || 'sage-minimalist';
    document.documentElement.setAttribute('data-theme', savedTheme);

    // 2. Re-bind event handlers on Astro page loads (ClientRouter compatibility)
    document.addEventListener('astro:page-load', () => {
      const activeTheme = localStorage.getItem('theme') || 'sage-minimalist';
      document.documentElement.setAttribute('data-theme', activeTheme);

      const themeSelect = document.getElementById('theme-select');
      if (themeSelect) {
        themeSelect.value = activeTheme;
        themeSelect.addEventListener('change', (e) => {
          const theme = e.target.value;
          localStorage.setItem('theme', theme);
          document.documentElement.setAttribute('data-theme', theme);
        });
      }

      const langSelect = document.getElementById('lang-select');
      if (langSelect) {
        langSelect.addEventListener('change', (e) => {
          const targetLang = e.target.value;
          const pathParts = window.location.pathname.split('/').filter(Boolean);
          
          if (pathParts.length === 0) {
            window.location.href = `/${targetLang}/directory`;
          } else {
            const supportedLangs = ['en-us', 'de-de', 'fr-fr'];
            if (supportedLangs.includes(pathParts[0])) {
              pathParts[0] = targetLang;
            } else {
              pathParts.unshift(targetLang);
            }
            window.location.href = `/${pathParts.join('/')}${window.location.search}`;
          }
        });
      }
    });
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Open+Sans:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <Analytics />
</head>
<body class="min-h-screen flex flex-col justify-between">
  
  <!-- Navigation Header -->
  <header class="border-b border-[var(--color-border)] bg-[var(--bg-primary)]/80 backdrop-blur-md sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-bold text-lg tracking-tight text-[var(--text-main)] hover:opacity-80 transition-opacity group">
        <img src="/logo.png" alt="IncentiveMapper Logo" class="w-9 h-9 object-contain rounded-lg transition-transform duration-300 group-hover:scale-105" width="36" height="36" />
        <span>IncentiveMapper</span>
      </a>
      <nav class="hidden md:flex items-center gap-6 text-sm font-semibold text-[var(--text-muted)]">
        <a href="/en-us/directory" class="hover:text-[var(--text-main)] transition-colors">Directory</a>
        <a href="/en-us/search" class="hover:text-[var(--text-main)] transition-colors">Search</a>
        <a href="/en-us/compare" class="hover:text-[var(--text-main)] transition-colors">Compare Sizing</a>
        <a href="/en-us/compliance" class="hover:text-[var(--text-main)] transition-colors">Compliance Guide</a>
              <a href="/en-us/blog" class="hover:text-[var(--text-main)] transition-colors">Blog</a>
</nav>
      <div class="flex items-center gap-3">
        <!-- Lang Selector -->
        <select 
          id="lang-select" 
          class="bg-[var(--bg-primary)] border border-[var(--color-border)] text-[var(--text-main)] text-sm rounded-xl px-2.5 py-1.5 outline-none font-semibold cursor-pointer transition-all hover:border-[var(--color-accent)]"
        >
          <option value="en-us" selected class="bg-[var(--bg-primary)] text-[var(--text-main)]">EN-US</option>
          <option value="de-de" class="bg-[var(--bg-primary)] text-[var(--text-main)]">DE-DE</option>
          <option value="fr-fr" class="bg-[var(--bg-primary)] text-[var(--text-main)]">FR-FR</option>
        </select>

        <!-- Theme Selector -->
        <select 
          id="theme-select"
          class="bg-[var(--bg-primary)] border border-[var(--color-border)] text-[var(--text-main)] text-sm rounded-xl px-2.5 py-1.5 outline-none font-semibold cursor-pointer transition-all hover:border-[var(--color-accent)]"
        >
          <option value="sage-minimalist" class="bg-[var(--bg-primary)] text-[var(--text-main)]">Sage Minimalist</option>
          <option value="dark-forest" class="bg-[var(--bg-primary)] text-[var(--text-main)]">Dark Forest Luxury</option>
          <option value="mint-tech" class="bg-[var(--bg-primary)] text-[var(--text-main)]">Mint & Clean Tech</option>
        </select>

        <a 
          href="/en-us/directory" 
          class="bg-[var(--color-accent)] text-white font-bold text-sm px-4 py-2 rounded-xl hover:opacity-90 transition-opacity"
        >
          Browse Directory
        </a>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-20 text-center flex-grow flex flex-col justify-center">
    <div class="space-y-6">
      <div class="inline-flex items-center gap-2 bg-green-500/10 text-[var(--text-muted)] text-xs font-bold px-3 py-1.5 rounded-full border border-green-500/20">
        ✨ 124 DSIRE Policy Categories Supported
      </div>
      <h1 class="text-5xl md:text-6xl font-black tracking-tight text-[var(--text-main)] leading-tight animate-fade-in">
        Alternative Energy Sizing & Policy Directory
      </h1>
      <p class="text-lg md:text-xl text-[var(--text-muted)] max-w-2xl mx-auto">
        Compute localized payback timelines, solar capacity limits, and battery peak avoidance offsets. Discover regional utility grants and tax credits.
      </p>

      <!-- Dynamic Zip Search Box -->
      <div class="max-w-md mx-auto pt-4">
        <div class="bg-[var(--bg-secondary)] border border-[var(--color-border)] p-2 rounded-2xl flex items-center gap-2 shadow-md">
          <input 
            type="text" 
            id="home-zip"
            placeholder="Enter city, state, ZIP code..." 
            class="bg-[var(--bg-primary)] border border-[var(--color-border)] text-[var(--text-main)] rounded-xl py-3 px-4 outline-none flex-grow font-semibold"
          />
          <button 
            id="home-search-btn"
            class="bg-[var(--color-accent)] hover:opacity-90 text-white font-bold px-6 py-3 rounded-xl transition-all"
          >
            Find Rebates
          </button>
        </div>
        <p id="search-feedback" class="text-xs text-red-500 mt-2 hidden"></p>
      </div>

      <!-- Quick Nav Links -->
      <div class="pt-8 space-y-3">
        <h3 class="text-sm font-bold text-[var(--text-muted)] uppercase tracking-wider">Featured Regional Portals</h3>
        <div class="flex flex-wrap justify-center gap-3">
          <a 
            href="/en-us/directory/us/california/los-angeles" 
            class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] px-4 py-2.5 rounded-xl text-sm font-bold transition-all hover:scale-105 inline-block text-[var(--text-main)] animate-fade-in"
          >
            ☀️ Los Angeles, CA (High Utility Rates)
          </a>
          <a 
            href="/en-us/directory/us/texas/houston" 
            class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] px-4 py-2.5 rounded-xl text-sm font-bold transition-all hover:scale-105 inline-block text-[var(--text-main)] animate-fade-in"
          >
            ⚡ Houston, TX (High Solar Yields)
          </a>
          <a 
            href="/en-us/directory/uk/england/london" 
            class="bg-[var(--bg-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] px-4 py-2.5 rounded-xl text-sm font-bold transition-all hover:scale-105 inline-block text-[var(--text-main)] animate-fade-in"
          >
            🇬🇧 London, UK (European SGR Feed-in)
          </a>
        </div>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-border)] bg-[var(--bg-primary)] py-8 text-center text-xs text-[var(--text-muted)] mt-12">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>&copy; 2026 IncentiveMapper. All rights reserved.</div>
      <div class="flex flex-wrap justify-center gap-6">
        <a href="/en-us/directory" class="hover:text-[var(--text-main)]">Directory</a>
        <a href="/en-us/search" class="hover:text-[var(--text-main)]">Search</a>
        <a href="/en-us/compare" class="hover:text-[var(--text-main)]">Compare Sizing</a>
        <a href="/en-us/compliance" class="hover:text-[var(--text-main)]">DSIRE Compliance Guide</a>
        <a href="/en-us/privacy" class="hover:text-[var(--text-main)]">Privacy Policy</a>
        <a href="/en-us/terms" class="hover:text-[var(--text-main)]">Terms</a>
      </div>
    </div>
  </footer>

  <script>
    const searchBtn = document.getElementById('home-search-btn');
    const zipInput = document.getElementById('home-zip') as HTMLInputElement;
    const feedback = document.getElementById('search-feedback');

    if (searchBtn && zipInput && feedback) {
      searchBtn.addEventListener('click', () => {
        const query = zipInput.value.trim();
        if (!query) {
          feedback.textContent = 'Please enter a search term or ZIP code.';
          feedback.classList.remove('hidden');
          return;
        }

        feedback.classList.add('hidden');
        
        // If it's a 5-digit ZIP code, redirect using first-digit mapping
        if (/^\d{5}$/.test(query)) {
          const firstDigit = query.charAt(0);
          if (firstDigit === '9') {
            window.location.href = '/en-us/directory/us/california/los-angeles';
          } else if (firstDigit === '7') {
            window.location.href = '/en-us/directory/us/texas/houston';
          } else {
            // Default search fallback
            window.location.href = `/en-us/search?q=${encodeURIComponent(query)}`;
          }
        } else {
          // Otherwise redirect to search page
          window.location.href = `/en-us/search?q=${encodeURIComponent(query)}`;
        }
      });

      // Allow enter key press
      zipInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          searchBtn.click();
        }
      });
    }
  </script>
</body>
</html>
